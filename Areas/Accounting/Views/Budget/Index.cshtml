@using PresupuestoMVC.Models.DTOs
@using PresupuestoMVC.Models.Entities
@using PresupuestoMVC.Helpers
@using System.Globalization
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rubros = ViewBag.Rubros as IEnumerable<CategoryResponseDto>;
    var meses = ViewBag.Meses as IEnumerable<int>;
    var anios = ViewBag.Anios as IEnumerable<int>;
    bool deficit = ViewBag.Deficit;
    var paginacion = ViewBag.Paginacion as PaginacionRespuestaDto<BudgetResponseDTO>;

    int totalPaginas = (int)Math.Ceiling((double)paginacion.TotalRegistros / ViewBag.TamañoPagina);
    int inicio = Math.Max(1, ViewBag.PaginaActual - 2);
    int fin = Math.Min(totalPaginas, ViewBag.PaginaActual + 2);
}
<!-- Header -->
<header class="oca-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold">
                    <i class="bi bi-wallet2 me-3"></i>
                    Presupuesto
                </h1>
                <p class="lead mb-0">Sistema de control Presupuesto</p>
            </div>
        </div>
    </div>
</header>

<div class="container">

    <!-- Filtros -->
    <section class="filter-section">
        <div class="row align-items-end">

           <!-- Filtrar por Rubro -->
            <div class="col-md-3">
                <label for="rubroFilter" class="form-label fw-semibold">
                    <i class="bi bi-tags me-1"></i>Filtrar por Rubro
                </label>
                <select class="form-select" id="rubroFilter" onchange="aplicarFiltros()">
                    <option value="">Todos los rubros</option>
                    @if (rubros != null)
                    {
                        foreach (var rubro in rubros)
                        {
                            <option value="@rubro.Id"
                                    selected="@(ViewBag.FiltroRubroId?.ToString() == rubro.Id.ToString())">
                                @rubro.nombreRubro
                            </option>
                        }
                    }
                </select>
            </div>

            <!-- Filtrar por Meses -->
            <div class="col-md-3">
                <label for="mesFilter" class="form-label fw-semibold">
                    <i class="bi bi-wallet2 me-1"></i>Filtrar por Meses
                </label>
                <select class="form-select" id="mesFilter" onchange="aplicarFiltros()">
                    <option value="">Todos los Meses</option>
                    @foreach (var mesItem in ViewBag.Meses)
                    {
                        <option value="@mesItem.Numero"
                                selected="@(ViewBag.FiltroMes?.ToString() == mesItem.Numero.ToString())">
                            @mesItem.Nombre
                        </option>
                    }
                </select>
            </div>

            <!-- Filtrar por Años -->
            <div class="col-md-2">
                <label for="aniosFilter" class="form-label fw-semibold">
                    <i class="bi bi-wallet2 me-1"></i>Filtrar por Años
                </label>
                <select class="form-select" id="aniosFilter" onchange="aplicarFiltros()">
                    <option value="">Todos los Años</option>
                    @foreach (var anio in ViewBag.Anios)
                    {
                        <option value="@anio"
                                selected="@(ViewBag.FiltroAnio?.ToString() == anio.ToString())">
                            @anio
                        </option>
                    }
                </select>
            </div>

            <!-- Deficit Limpiar y Crear -->
            <div class="col-md-4">
                <div class="d-flex gap-2 align-items-end">
                    <!-- Filtro Deficit -->
                    <div>
                        <label>Deficit</label>
                        <input onchange="aplicarFiltros()"
                            id="checkboxDeficit" type="checkbox" name="name" value=""
                               class="form-check-input" @(ViewBag.Deficit ? "checked" : "") />
                    </div>
                    <!-- Botón Limpiar -->
                    <button class="btn btn-outline-secondary" id="btnLimpiarFiltros"
                            onclick="limpiarFiltros()">
                        <i class="bi bi-arrow-clockwise"></i>Limpiar
                    </button>
                    <!-- Botón Crear -->
                    <button class="btn btn-outline-success" id="btnNuevoRubro"
                            onclick="abrirModalCrear()">
                        <i class="bi bi-plus-circle"></i>Nuevo Presupuesto
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- Loading Spinner -->
    @* <div class="loading-spinner" id="loadingSpinner">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 text-muted">Cargando gastos...</p>
    </div> *@

    <!-- Grilla presupuesto -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-oca">
            <thead>
                <tr>
                    <th scope="col">Rubro</th>
                    <th scope="col">Valor Inicial</th>
                    <th scope="col">Valor Gastado</th>
                    <th scope="col">Disponible</th>
                    <th scope="col">%</th>
                    <th scope="col">Mes</th>
                    <th scope="col">Año</th>
                    <th scope="col">Acciones</th>
                </tr>
            </thead>
            <tbody id="rubroTableBody">
                @if (paginacion.Datos != null && paginacion.Datos.Any())
                {
                    foreach (var rubro in paginacion.Datos)
                    {
                        <tr>
                            @{
                                var total = rubro.valorInicial;
                                var gastado = rubro.valorGastado;
                                var disponible = total - gastado;

                                var porcentajeGastado = total > 0
                                ? Math.Min((gastado / total) * 100, 100)
                                : 0;

                                var porcentajeDisponible = 100 - porcentajeGastado;

                                var barraColor = disponible < 0 ? "bg-danger" : "bg-primary";
                            }
                            <td data-rubroTypeId="@rubro.tipoRubroNombre.ToString()">
                                @rubro.tipoRubroNombre.ToString()
                            </td>
                            <td data-valorInicial="@rubro.valorInicial">
                                @total.ToString("C0", new CultureInfo("es-AR"))
                            </td>
                            <td data-valorGastado="@rubro.valorGastado">
                                @gastado.ToString("C0", new CultureInfo("es-AR"))
                            </td>
                            <td>
                                @disponible.ToString("C0", new CultureInfo("es-AR"))
                            </td>
                            <td style="min-width:70px;">
                                <div class="progress border border-secondary mb-1" style="height: 16px;">
                                    <div class="progress-bar @barraColor"
                                         role="progressbar"
                                         style="width:@porcentajeGastado.ToString("0.##")%">
                                    </div>

                                    @if (disponible >= 0)
                                    {
                                        <div class="progress-bar bg-light"
                                             role="progressbar"
                                             style="width:@porcentajeDisponible.ToString("0.##")%">
                                        </div>
                                    }
                                </div>
                            </td>

                            <td data-mes="@rubro.Mes">
                                @MonthHelper.MonthName(rubro.Mes)
                            </td>
                            <td data-anio="@rubro.Anio">
                                @rubro.Anio
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary me-1 btn-editar-rubro" 
                                    onclick="abrirModalEditar(
                                        '@rubro.Id', 
                                        '@rubro.RubroTypeId',
                                        '@rubro.valorInicial',
                                        '@rubro.valorGastado',
                                        '@rubro.Mes',
                                        '@rubro.Anio'
                                    )">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn btn-sm btn-danger btn-eliminar-rubro" 
                                    onclick="abrirModalEliminar(
                                        '@rubro.Id', 
                                        '@rubro.tipoRubroNombre',
                                        '@rubro.valorInicial',
                                        '@rubro.valorGastado',
                                        '@rubro.Mes',
                                        '@rubro.Anio'
                                    )">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <nav aria-label="Paginación de rubro">
            <ul class="pagination justify-content-center">
                <!-- Botón Anterior -->
                <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                    @if (ViewBag.PaginaActual > 1)
                    {
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               rubroTypeId = ViewBag.FiltroRubroId, 
                               mes = ViewBag.FiltroMes,
                               anio = ViewBag.FiltroAnio,
                               pagina = ViewBag.PaginaActual - 1, 
                               tamañoPagina = ViewBag.TamañoPagina 
                           })">
                            Anterior
                        </a>
                    }
                    else
                    {
                        <span class="page-link">Anterior</span>
                    }
                </li>
            
                @for (int i = inicio; i <= fin; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               rubroTypeId = ViewBag.FiltroRubroId, 
                               mes = ViewBag.FiltroMes,
                               anio = ViewBag.FiltroAnio, 
                               pagina = i, 
                               tamañoPagina = ViewBag.TamañoPagina 
                           })">
                            @i
                        </a>
                    </li>
                }
                <!-- Botón Siguiente -->
                <li class="page-item @(ViewBag.PaginaActual >= totalPaginas ? "disabled" : "")">
                    @if (ViewBag.PaginaActual < totalPaginas)
                    {
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               rubroTypeId = ViewBag.FiltroRubroId, 
                               mes = ViewBag.FiltroMes,
                               anio = ViewBag.FiltroAnio, 
                               pagina = ViewBag.PaginaActual + 1, 
                               tamañoPagina = ViewBag.TamañoPagina 
                           })">
                            Siguiente
                        </a>
                    }
                    else
                    {
                        <span class="page-link">Siguiente</span>
                    }
                </li>
            </ul>
    </nav>
</div>

<!-- Modal de Creación -->
<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-success">
            <!-- Header verde -->
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Presupuesto
                </h5>
                <button type="button" class="btn-close btn-close-white" 
                        data-bs-dismiss="modal"></button>
            </div>
            
            <!-- Formulario -->
            <form action="@Url.Action("Create")" method="post">
                <div class="modal-body">
                    <!-- Rubro -->
                    <div class="mb-3">
                        <label for="crearRubroId" class="form-label">Rubro</label>
                        <select id="crearRubroId" name="RubroTypeId" 
                                class="form-select" required>
                            <option value="">Seleccionar rubro...</option>
                            @if (ViewBag.Rubros != null)
                            {
                                foreach (var rubro in ViewBag.Rubros)
                                {
                                    <option value="@rubro.Id">@rubro.nombreRubro</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Valor Inicial -->
                    <div class="mb-3">
                        <label for="crearValorInicial" class="form-label">Valor Inicial</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" id="crearValorInicial" name="ValorInicial" 
                                   class="form-control" 
                                   min="0" 
                                   step="1" 
                                   placeholder="0" 
                                   required />
                        </div>
                    </div>
                    
                    <!-- Mes -->
                    <div class="mb-3">
                        <label for="crearMes" class="form-label">Mes</label>
                        <select id="crearMes" name="Mes" 
                                class="form-select" required>
                            <option value="-1">Seleccionar mes...</option>
                            @if (ViewBag.Meses != null)
                            {
                                foreach (var mes in ViewBag.Meses)
                                {
                                    <option value="@mes.Numero">@mes.Nombre</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Año -->
                    <div class="mb-3">
                        <label for="crearAnio" class="form-label">Año</label>
                        <select id="crearAnio" name="Anio" 
                                class="form-select" required>
                            <option value="-1">Seleccionar año...</option>
                            @if (ViewBag.Anios != null)
                            {
                                foreach (var anio in ViewBag.Anios)
                                {
                                    <option value="@anio"selected="@(ViewBag.FiltroAnio?.ToString() == anio.ToString())">
                                        @anio
                                    </option>
                                }
                            }
                        </select>
                    </div>
                
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" 
                                data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Crear Presupuesto
                        </button>
                    </div>
               </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Edición -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form action="@Url.Action("Edit")" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>Editar Rubro
                    </h5>
                    <button type="button" class="btn-close btn-close-white" 
                            data-bs-dismiss="modal"></button>
                </div>
                
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="editRubroId" name="Id" value=""/>
                    
                    <!-- Rubro -->
                    <div class="mb-3">
                        <label for="editRubroTypeId" class="form-label">Rubro</label>
                        <select id="editRubroTypeId" name="RubroTypeId" 
                                class="form-select" required>
                            <option value="">Seleccionar rubro...</option>
                            @if (ViewBag.Rubros != null)
                            {
                                foreach (var rubro in ViewBag.Rubros)
                                {
                                    <option value="@rubro.Id">@rubro.nombreRubro</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <!-- Valor Inicial -->
                    <div class="mb-3">
                        <label for="editValorInicial" class="form-label">Valor Inicial</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" id="editValorInicial" name="ValorInicial" 
                                   class="form-control" 
                                   min="0" 
                                   step="1" 
                                   placeholder="0" 
                                   required />
                        </div>
                    </div>
                    
                    <!-- Mes -->
                    <div class="mb-3">
                        <label for="editMes" class="form-label">Mes</label>
                        <select id="editMes" name="Mes" 
                                class="form-select" required>
                            <option value="">Seleccionar mes...</option>
                            @if (ViewBag.Meses != null)
                            {
                                foreach (var mes in ViewBag.Meses)
                                {
                                    <option value="@mes.Numero"
                                            selected="@(ViewBag.FiltroMes?.ToString() == mes.Numero.ToString())">
                                        @mes.Nombre
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Año -->
                    <div class="mb-3">
                        <label for="editAnio" class="form-label">Año</label>
                        <select id="editAnio" name="Anio" 
                                class="form-select" required>
                            <option value="">Seleccionar año...</option>
                            @if (ViewBag.Anios != null)
                            {
                                foreach (var anio in ViewBag.Anios)
                                {
                                    <option value="@anio"selected="@(ViewBag.FiltroAnio?.ToString() == anio.ToString())">
                                        @anio
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" 
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" 
                        data-bs-dismiss="modal"></button>
            </div>
            
            <!-- Formulario -->
            <form action="@Url.Action("Delete")" method="post">
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="deleteRubroId" name="id" />
                    
                    <!-- Mensaje de confirmación -->
                    <div class="text-center">
                        <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">¿Estás seguro de eliminar este rubro?</h5>
                        <p class="text-muted">
                            Esta acción no se puede deshacer. El rubro será eliminado permanentemente.
                        </p>
                        
                        <!-- Información del gasto a eliminar -->
                        <div class="alert alert-light mt-3 text-start" id="deleteRubroInfo">
                            <div class="row">
                                <div class="col-6"><strong>ID:</strong> <span id="deleteRubroIdText">-</span></div>
                                <div class="col-6"><strong>Rubro:</strong> <span id="deleteRubroType">-</span></div>
                                <div class="col-6 mt-2"><strong>Valor Inicial:</strong> $<span id="deleteValorInicial">-</span></div>
                                <div class="col-6 mt-2"><strong>Mes:</strong> <span id="deleteMes">-</span></div>
                                <div class="col-6 mt-3"><strong>Año:</strong> <span id="deleteAnio">-</span></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" 
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>

    function abrirModalEditar(id, rubroId, valorInicial, mes, anio) {
        // Llenar formulario
        document.getElementById('editRubroId').value = id;
        document.getElementById('editRubroTypeId').value = rubroId;
        document.getElementById('editValorInicial').value = valorInicial;
        document.getElementById('editMes').value = mes;
        document.getElementById('editAnio').value = anio;
    
        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalEditar'));
        modal.show();
    }

    function abrirModalCrear() {
        // Resetear formulario
        document.getElementById('crearRubroId').value = '';
        document.getElementById('crearValorInicial').value = '';
        document.getElementById('crearMes').value = '';
        document.getElementById('crearAnio').value = '';
    
        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalCrear'));
        modal.show();
    }

    function abrirModalEliminar(id, rubroId, valorInicial, mes, anio) {
        // Llenar formulario
        document.getElementById('deleteRubroId').value = id;

        const meses = [
            "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
            "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"
        ];
    
        // Convertir número a nombre
        const mesNombre = meses[mes - 1] || `Mes ${mes}`;

        document.getElementById('deleteRubroIdText').innerText = id;
        document.getElementById('deleteRubroType').innerText = rubroId;
        document.getElementById('deleteValorInicial').innerText = valorInicial;
        document.getElementById('deleteMes').innerText = mesNombre;
        document.getElementById('deleteAnio').innerText = anio;
    
        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        modal.show();
    }

    function limpiarFiltros() {
        window.location.href = '@Url.Action("Index", "Budget")';
    }

    function aplicarFiltros() {
        const rubroId = document.getElementById('rubroFilter').value;
        const mes = document.getElementById('mesFilter').value;
        const anio = document.getElementById('aniosFilter').value;
        const deficit = document.getElementById('checkboxDeficit').checked;
        console.log("rubroId:", rubroId)
        console.log("mes:", mes)
        console.log("anio:", anio)
        console.log("deficit:",deficit)

        // Construir URL con parámetros
        let url = '@Url.Action("Index", "Budget")';
        const params = new URLSearchParams();

        if (rubroId) params.append('rubroTypeId', rubroId);
        if (mes) params.append('mes', mes);
        if (anio) params.append('anio', anio);
        params.append('deficit', deficit);


        // Mantener página actual
        params.append('pagina', 1);
        params.append('tamañoPagina', @ViewBag.TamañoPagina);

        if (params.toString()) {
            url += '?' + params.toString();
        }

        window.location.href = url;
    }

</script>