@{
    ViewData["Title"] = "Diario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --erp-primary: #5b5bd6;
            --erp-primary-soft: #eef0ff;
            --erp-primary-dark: #4343b7;
            --erp-success-soft: #e8fbf4;
            --erp-success: #1f9d6b;
            --erp-danger-soft: #fff0f1;
            --erp-danger: #da4b5b;
            --erp-text: #202636;
            --erp-muted: #7b8192;
            --erp-border: #e8ebf3;
            --erp-bg: #f5f7fb;
            --erp-card: #ffffff;
            --erp-sidebar: #ffffff;
        }

        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background: var(--erp-bg);
            color: var(--erp-text);
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        }

        .layout {
            min-height: 100vh;
        }

        .sidebar {
            width: 272px;
            background: var(--erp-sidebar);
            border-right: 1px solid var(--erp-border);
            position: fixed;
            inset: 0 auto 0 0;
            padding: 1.25rem 1rem;
            overflow-y: auto;
        }

        .brand {
            font-size: 2rem;
            font-weight: 800;
            color: #111827;
            margin-bottom: 1.5rem;
            padding: 0 .5rem;
        }

        .nav-group-title {
            font-size: .74rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #98a0b3;
            margin: 1.1rem 0 .55rem;
            padding: 0 .75rem;
        }

        .sidebar .nav-link {
            border-radius: 16px;
            color: #4d5568;
            padding: .82rem .9rem;
            display: flex;
            align-items: center;
            gap: .8rem;
            font-weight: 600;
            margin-bottom: .2rem;
        }

            .sidebar .nav-link i {
                font-size: 1.1rem;
            }

            .sidebar .nav-link:hover {
                background: #f8f9fe;
                color: var(--erp-primary-dark);
            }

            .sidebar .nav-link.active {
                background: var(--erp-primary-soft);
                color: var(--erp-primary-dark);
            }

        .sidebar .nav-sub {
            margin-left: 2.35rem;
            display: flex;
            flex-direction: column;
            gap: .2rem;
            margin-bottom: .5rem;
        }

            .sidebar .nav-sub a {
                color: #6b7280;
                text-decoration: none;
                padding: .5rem .75rem;
                border-radius: 12px;
                font-weight: 500;
            }

                .sidebar .nav-sub a:hover,
                .sidebar .nav-sub a.active {
                    background: #f6f7fc;
                    color: var(--erp-primary-dark);
                }

        .content {
            margin-left: 272px;
            padding: 2rem;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .searchbox {
            position: relative;
            width: min(360px, 100%);
        }

            .searchbox i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #97a0b1;
            }

            .searchbox .form-control {
                padding-left: 2.45rem;
            }

        .page-head {
            display: flex;
            justify-content: space-between;
            align-items: start;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .page-title {
            font-size: 2.4rem;
            line-height: 1.1;
            font-weight: 800;
            margin: 0 0 .35rem;
            letter-spacing: -.03em;
        }

        .page-subtitle {
            margin: 0;
            color: var(--erp-muted);
            font-size: 1rem;
        }

        .erp-card {
            background: var(--erp-card);
            border: 1px solid var(--erp-border);
            border-radius: 24px;
            box-shadow: 0 12px 34px rgba(31, 41, 55, .05);
        }

        .metric-card {
            padding: 1.2rem;
            height: 100%;
        }

        .metric-icon {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--erp-primary-soft);
            color: var(--erp-primary-dark);
            font-size: 1.2rem;
            margin-bottom: .85rem;
        }

        .metric-label {
            color: var(--erp-muted);
            font-size: .9rem;
            margin-bottom: .2rem;
        }

        .metric-value {
            font-size: 1.65rem;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .filters-card,
        .table-card {
            overflow: hidden;
        }

        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            padding: 1.25rem 1.25rem 0;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 800;
            margin: 0;
        }

        .section-subtitle {
            color: var(--erp-muted);
            margin: .15rem 0 0;
            font-size: .92rem;
        }

        .filters-body {
            padding: 1.25rem;
        }

        .form-label {
            font-size: .78rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #7b8192;
            margin-bottom: .45rem;
        }

        .form-control,
        .form-select {
            min-height: 48px;
            border-radius: 14px;
            border-color: var(--erp-border);
            box-shadow: none !important;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: #c9cffc;
            }

        .btn {
            min-height: 48px;
            border-radius: 14px;
            font-weight: 700;
            padding: .75rem 1rem;
        }

        .btn-primary {
            background: var(--erp-primary);
            border-color: var(--erp-primary);
        }

            .btn-primary:hover {
                background: var(--erp-primary-dark);
                border-color: var(--erp-primary-dark);
            }

        .btn-soft {
            background: #fff;
            border: 1px solid var(--erp-border);
            color: #566074;
        }

            .btn-soft:hover {
                background: #f8f9fd;
                border-color: #dfe4ef;
                color: #394150;
            }

        .btn-success-soft {
            background: var(--erp-success-soft);
            color: var(--erp-success);
            border: 1px solid #c9f1df;
        }

        .quick-filters {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            margin-top: .9rem;
        }

        .quick-chip {
            background: #f8f9fd;
            border: 1px solid var(--erp-border);
            color: #5f6678;
            border-radius: 999px;
            padding: .45rem .85rem;
            font-size: .88rem;
            font-weight: 700;
            text-decoration: none;
        }

            .quick-chip.active,
            .quick-chip:hover {
                background: var(--erp-primary-soft);
                border-color: #d8ddff;
                color: var(--erp-primary-dark);
            }

        .table-tools {
            padding: 1rem 1.25rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: .75rem;
        }

        .table-modern {
            margin-bottom: 0;
            vertical-align: middle;
        }

            .table-modern thead th {
                background: #fafbff;
                color: #677085;
                font-size: .78rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                font-weight: 800;
                border-bottom: 1px solid var(--erp-border);
                padding: 1rem 1.25rem;
                white-space: nowrap;
            }

            .table-modern tbody td {
                border-color: #eef1f7;
                padding: 1rem 1.25rem;
            }

            .table-modern tbody tr:hover {
                background: #fcfcff;
            }

        .money {
            font-weight: 800;
            color: #1f2937;
            white-space: nowrap;
        }

        .badge-soft {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .45rem .75rem;
            border-radius: 999px;
            font-weight: 700;
            font-size: .82rem;
            border: 1px solid transparent;
        }

        .badge-rubro {
            background: #f4f1ff;
            color: #5c3fc4;
            border-color: #e4dcff;
        }

        .badge-cuenta {
            background: #eef8ff;
            color: #1f72b8;
            border-color: #d9ecfb;
        }

        .note-cell {
            max-width: 320px;
        }

        .truncate {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .action-group {
            display: inline-flex;
            gap: .5rem;
        }

        .icon-btn {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            border: 1px solid var(--erp-border);
            background: #fff;
            color: #5d6678;
            text-decoration: none;
        }

            .icon-btn:hover {
                background: #f8f9fd;
                color: var(--erp-primary-dark);
                border-color: #dde3f1;
            }

        .icon-btn-danger:hover {
            background: var(--erp-danger-soft);
            color: var(--erp-danger);
            border-color: #ffd6dc;
        }

        .table-footer {
            padding: 1rem 1.25rem 1.25rem;
            border-top: 1px solid var(--erp-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pagination .page-link {
            border-radius: 12px !important;
            border: 1px solid var(--erp-border);
            color: #586072;
            margin: 0 .15rem;
            min-width: 38px;
            text-align: center;
        }

        .pagination .page-item.active .page-link {
            background: var(--erp-primary);
            border-color: var(--erp-primary);
        }

        @@media (max-width: 991.98px) {
            .sidebar {
                position: static;
                width: 100%;
                border-right: 0;
                border-bottom: 1px solid var(--erp-border);
            }

            .content {
                margin-left: 0;
                padding: 1rem;
            }

            .page-title {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="layout d-lg-flex">
        <aside class="sidebar">
            <div class="brand">Avisur</div>

            <div class="nav-group-title">General</div>
            <nav class="nav flex-column">
                <a class="nav-link" href="#"><i class="bi bi-house-door"></i> Menú</a>
            </nav>

            <div class="nav-group-title">Presupuesto</div>
            <nav class="nav flex-column">
                <a class="nav-link active" href="#"><i class="bi bi-wallet2"></i> Presupuesto</a>
                <div class="nav-sub">
                    <a href="#">Listado</a>
                    <a href="#" class="active">Diario</a>
                    <a href="#">Rubros</a>
                    <a href="#">Cuentas</a>
                </div>
            </nav>

            <div class="nav-group-title">Ventas</div>
            <nav class="nav flex-column">
                <a class="nav-link" href="#"><i class="bi bi-box-seam"></i> Ventas</a>
            </nav>

            <div class="nav-group-title">Sistema</div>
            <nav class="nav flex-column">
                <a class="nav-link" href="#"><i class="bi bi-person-gear"></i> Usuarios</a>
            </nav>
            <div class="mt-auto pt-3 border-top" style="position:sticky; bottom:0; background:var(--erp-sidebar);">
                <div class="d-flex align-items-center gap-2 p-2">
                    <div style="width:40px;height:40px;border-radius:50%;background:#dfe3ff;display:flex;align-items:center;justify-content:center;font-weight:700;">
                        CM
                    </div>
                    <div class="flex-grow-1">
                        <div style="font-weight:700;font-size:.9rem;">Cristian</div>
                        <div style="font-size:.75rem;color:var(--erp-muted);">Administrador</div>
                    </div>
                </div>
                <div class="d-grid p-2">
                    <button class="btn btn-soft w-100">
                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                    </button>
                </div>
            </div>
        </aside>

        <main class="content flex-grow-1">
            <div class="topbar">
                <div class="searchbox">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="text" placeholder="Buscar movimientos, rubros o notas..." />
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-soft"><i class="bi bi-download me-2"></i>Exportar</button>
                    <button class="btn btn-success-soft"><i class="bi bi-plus-lg me-2"></i>Nuevo movimiento</button>
                </div>
            </div>

            <div class="page-head">
                <div>
                    <h1 class="page-title">Diario</h1>
                    <p class="page-subtitle">Control y seguimiento diario de gastos y movimientos por rubro, cuenta y período.</p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6 col-xl-3">
                    <div class="erp-card metric-card">
                        <div class="metric-icon"><i class="bi bi-journal-text"></i></div>
                        <div class="metric-label">Movimientos del mes</div>
                        <div class="metric-value">148</div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="erp-card metric-card">
                        <div class="metric-icon"><i class="bi bi-cash-stack"></i></div>
                        <div class="metric-label">Total del período</div>
                        <div class="metric-value">$ 1.245.800</div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="erp-card metric-card">
                        <div class="metric-icon"><i class="bi bi-credit-card-2-front"></i></div>
                        <div class="metric-label">Cuenta principal</div>
                        <div class="metric-value">Mercado Pago</div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="erp-card metric-card">
                        <div class="metric-icon"><i class="bi bi-tags"></i></div>
                        <div class="metric-label">Rubro principal</div>
                        <div class="metric-value">Mercadería</div>
                    </div>
                </div>
            </div>

            <!-- Filtros -->
            <section class="erp-card filters-card mb-4">
                <div class="section-head">
                    <div>
                        <h2 class="section-title">Filtros</h2>
                        <p class="section-subtitle">Aplicá filtros para encontrar movimientos más rápido.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-soft"><i class="bi bi-arrow-clockwise me-2"></i>Limpiar</button>
                        <button class="btn btn-primary"><i class="bi bi-funnel me-2"></i>Buscar</button>
                    </div>
                </div>

                <div class="filters-body">
                    <form class="row g-3 align-items-end">
                        <div class="col-md-6 col-xl-2">
                            <label class="form-label">Desde</label>
                            <input type="date" class="form-control" value="2026-03-01" />
                        </div>
                        <div class="col-md-6 col-xl-2">
                            <label class="form-label">Hasta</label>
                            <input type="date" class="form-control" value="2026-03-31" />
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">Rubro</label>
                            <select class="form-select">
                                <option>Todos los rubros</option>
                                <option>Mercadería</option>
                                <option>Fruta</option>
                                <option>Gastos diarios</option>
                            </select>
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">Cuenta</label>
                            <select class="form-select">
                                <option>Todas las cuentas</option>
                                <option>Mercado Pago</option>
                                <option>Banco Galicia</option>
                            </select>
                        </div>
                        <div class="col-xl-2">
                            <label class="form-label">Texto libre</label>
                            <input type="text" class="form-control" placeholder="Buscar nota o monto" />
                        </div>
                    </form>

                    <div class="quick-filters">
                        <a href="#" class="quick-chip active">Hoy</a>
                        <a href="#" class="quick-chip">Últimos 7 días</a>
                        <a href="#" class="quick-chip">Este mes</a>
                        <a href="#" class="quick-chip">Mes anterior</a>
                        <a href="#" class="quick-chip">Solo Mercado Pago</a>
                    </div>
                </div>
            </section>

            <section class="erp-card table-card">
                <div class="table-tools">
                    <div>
                        <h2 class="section-title">Movimientos registrados</h2>
                        <p class="section-subtitle">Mostrando 8 de 148 registros</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-soft"><i class="bi bi-sort-down me-2"></i>Ordenar</button>
                        <button class="btn btn-soft"><i class="bi bi-printer me-2"></i>Imprimir</button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-modern table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th class="text-end">Monto</th>
                                <th>Rubro</th>
                                <th>Cuenta</th>
                                <th>Nota</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="random-data"></tbody>

                        <script>
                            const rubros = ["Mercadería", "Transporte", "Servicios", "Educación", "Salud", "Ocio"];
                            const cuentas = ["Mercado Pago", "Banco Galicia", "Efectivo"];
                            const notas = ["Compra semanal", "Pago factura", "Gasto imprevisto", "Suscripción", "Pago colegio", "Supermercado"];

                            function randomDate() {
                                const start = new Date(2026, 2, 1);
                                const end = new Date(2026, 2, 31);
                                return new Date(start.getTime() + Math.random() * (end - start));
                            }

                            function formatDate(date) {
                                return date.toLocaleDateString('es-AR');
                            }

                            function randomAmount() {
                                return Math.floor(Math.random() * 50000) + 500;
                            }

                            function generateRow() {
                                const date = formatDate(randomDate());
                                const amount = randomAmount().toLocaleString('es-AR');
                                const rubro = rubros[Math.floor(Math.random() * rubros.length)];
                                const cuenta = cuentas[Math.floor(Math.random() * cuentas.length)];
                                const nota = notas[Math.floor(Math.random() * notas.length)];

                                return `
                                    <tr>
                                        <td>${date}</td>
                                        <td class="text-end money">$ ${amount}</td>
                                        <td><span class="badge-soft badge-rubro">${rubro}</span></td>
                                        <td><span class="badge-soft badge-cuenta">${cuenta}</span></td>
                                        <td class="note-cell"><div class="truncate">${nota}</div></td>
                                        <td class="text-end">
                                            <div class="action-group">
                                                <a href="#" class="icon-btn"><i class="bi bi-pencil-square"></i></a>
                                                <a href="#" class="icon-btn icon-btn-danger"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>`;
                            }

                            const tbody = document.getElementById("random-data");
                            for (let i = 0; i < 10; i++) {
                                tbody.innerHTML += generateRow();
                            }
                        </script>
                    </table>
                </div>

                <div class="table-footer">
                    <small class="text-muted">Página 1 de 19</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item disabled"><a class="page-link" href="#">Anterior</a></li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item"><a class="page-link" href="#">Siguiente</a></li>
                        </ul>
                    </nav>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
