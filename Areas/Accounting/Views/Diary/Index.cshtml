@using PresupuestoMVC.Models.DTOs
@using PresupuestoMVC.Models.Entities
@using System.Globalization
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Diario";
    var rubros = ViewBag.Rubros as IEnumerable<CategoryResponseDto>;
    var periodos = ViewBag.Periodos as IEnumerable<PeriodResponseDto>;
    var cuentas = ViewBag.Cuentas as IEnumerable<CuentaResponseDto>;
    var paginacion = ViewBag.Paginacion as PaginacionRespuestaDto<GastoResponseDto>;
    var items = ViewBag.itemsCount;
    var totalGastos = ViewBag.TotalGastos;

    int totalPaginas = (int)Math.Ceiling((double)paginacion.TotalRegistros / ViewBag.TamañoPagina);
    int inicio = Math.Max(1, ViewBag.PaginaActual - 2);
    int fin = Math.Min(totalPaginas, ViewBag.PaginaActual + 2);

    Func<DateTime, string> FormatPeriodo = (fecha) =>
    {
        var cultureInfo = new CultureInfo("es-ES");
        string monthName = cultureInfo.DateTimeFormat.GetMonthName(fecha.Month);
        string capitalizedMonth = string.Concat(monthName[0].ToString().ToUpper(), monthName.AsSpan(1));
        return $"{capitalizedMonth} {fecha.Year}";
    };
}
<main class="flex-grow-1 container-main">
    <!-- Header -->
    <div class="topbar">
        <div class="searchbox">
            <i class="bi bi-search"></i>
            <input class="form-control" type="text" placeholder="Buscar movimientos, rubros o notas..." />
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success-soft" onclick="AbrirModalCrearGasto()"><i class=" bi bi-plus-lg me-2" id="btnNuevoGasto"></i>Nuevo gasto</button>
        </div>
    </div>
    <div class="page-head">
        <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
            <p class="page-subtitle">Control y seguimiento diario de gastos y movimientos por rubro, cuenta y período.</p>
        </div>
    </div>

    <!-- informacion util rapida -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-journal-text"></i></div>
                <div class="metric-label">Movimientos del mes</div>
                <div class="metric-value">148</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="metric-label">Total del período</div>
                <div class="metric-value">$ 1.245.800</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-credit-card-2-front"></i></div>
                <div class="metric-label">Cuenta principal</div>
                <div class="metric-value">Mercado Pago</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-tags"></i></div>
                <div class="metric-label">Rubro principal</div>
                <div class="metric-value">Mercadería</div>
            </div>
        </div>
    </div>

    <section class="erp-card filters-card mb-4">
         <!-- Filtros -->
        <div class="section-head">
           <div>
             <h2 class="section-title">Filtros</h2>
              <p class="section-subtitle">Aplicá filtros para encontrar movimientos más rápido.</p>
           </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-soft" onclick="limpiarFiltrosGasto()">
                    <i class="bi bi-arrow-clockwise me-2"></i>Limpiar
                </button>
            </div>
        </div>

            <div class="filters-body">
                <div class="row g-3">

                    <!-- Desde -->
                    <div class="col-md-2">
                        <label class="form-label">Desde</label>
                        <input type="date" class="form-control"
                               id="fechaDesde"
                               value="@ViewBag.FechaDesde"
                               onchange="aplicarFiltros()" />
                    </div>

                    <!-- Hasta -->
                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <input type="date" class="form-control"
                               id="fechaHasta"
                               value="@ViewBag.FechaHasta"
                               onchange="aplicarFiltros()" />
                    </div>

                    @* los nombres de los rubros fijos se muestran primero  *@
                    @{
                        var rubrosFijos = new[] { 34, 35 };

                        var rubrosOrdenados = rubros
                        .OrderByDescending(r => rubrosFijos.Contains(r.Id));
                    }


                    <!-- Rubro -->
                    <div class="col-md-3">
                        <label class="form-label">Rubro</label>
                        <select class="form-select" id="rubroFilter" onchange="aplicarFiltros()">
                            <option value="">Todos</option>
                            @foreach (var rubro in rubrosOrdenados)
                            {
                                <option value="@rubro.Id"
                                        selected="@(ViewBag.FiltroRubroId?.ToString() == rubro.Id.ToString())">
                                    @rubro.nombreRubro
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Cuenta -->
                    <div class="col-md-3">
                        <label class="form-label">Cuenta</label>
                        <select class="form-select" id="cuentaFilter" onchange="aplicarFiltros()">
                            <option value="">Todas</option>
                            @foreach (var cuenta in cuentas)
                            {
                                <option value="@cuenta.Id"
                                        selected="@(ViewBag.FiltroCuentaId?.ToString() == cuenta.Id.ToString())">
                                    @cuenta.nombreCuenta
                                </option>
                            }
                        </select>
                    </div>

                </div>
            <div class="quick-filters">
                <a href="#" class="quick-chip active">Hoy</a>
                <a href="#" class="quick-chip">Últimos 7 días</a>
                <a href="#" class="quick-chip">Este mes</a>
                <a href="#" class="quick-chip">Mes anterior</a>
                <a href="#" class="quick-chip">Solo Mercado Pago</a>
            </div>
            </div>
    </section>

    <!-- Grilla de Gastos -->
    <section class="erp-card table-card">
        <div class="table-tools">
            <div>
                <h2 class="section-title">Movimientos registrados</h2>
                <p class="section-subtitle">
                    Mostrando @items de @totalGastos
                </p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th class="text-end">Monto</th>
                        <th>Rubro</th>
                        <th>Cuenta</th>
                        <th>Nota</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>


                <tbody id="gastosTableBody">
                    <!-- Los gastos se cargarán dinámicamente -->
                    @if (paginacion.Datos != null && paginacion.Datos.Any())
                    {
                        foreach (var gasto in paginacion.Datos)
                        {
                            <tr class="@(gasto.Tipo == "Transferencia"
                            ? "table-warning fw-semibold"
                                : gasto.Tipo == "Ingreso"
                                ? "table-success fw-semibold"
                                : "")">
                                <td data-fecha="@gasto.Fecha.ToString("yyyy-MM-dd")">
                                    @gasto.Fecha.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-end money" data-monto="@gasto.Monto">
                                    @gasto.Monto.ToString("C0", new CultureInfo("es-AR"))
                                </td>
                                <td><span class="badge-soft badge-rubro" data-rubroid="@gasto.RubroTypeId">
                                    @(gasto.RubroTypeNombre ?? gasto.Tipo)
                                </span></td>
                                <td><span class="badge-soft badge-cuenta" data-cuentaid="@gasto.CuentaId">
                                    @gasto.CuentaNombre
                                </span></td>
                                <td class="note-cell"><div class="truncate">@(gasto.Nota ?? "")</div></td>
                            <td class="text-end">
                                    <button class="icon-btn"
                                            onclick="AbrirModalEditarGasto(
                                            '@gasto.Id',
                                            '@gasto.Fecha.ToString("yyyy-MM-dd")',
                                            @gasto.Monto.ToString().Replace(",", "."),
                                            '@Html.Raw(gasto.Nota?.Replace("'", "\\'") ?? "")',
                                            @gasto.RubroTypeId,
                                            @gasto.CuentaId,
                                            @gasto.PeriodoId
                                        )">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="icon-btn icon-btn-danger"
                                            onclick="AbrirModalEliminarGasto(
                                            '@gasto.Id',
                                            '@gasto.Fecha.ToString("dd/MM/yyyy")',
                                            @gasto.Monto.ToString().Replace(",", "."),
                                            '@gasto.RubroTypeNombre',
                                            '@gasto.CuentaNombre'
                                        )">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No hay gastos para mostrar
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Paginación -->
        <div class="table-footer">
            <small class="text-muted">Página 1 de 19</small>
            <nav aria-label="Paginación de gastos">
                <ul class="pagination pagination-sm mb-0">
                    <!-- Botón Anterior -->
                    <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                        @if (ViewBag.PaginaActual > 1)
                        {
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                               rubroTypeId = ViewBag.FiltroRubroId,
                               cuentaId = ViewBag.FiltroCuentaId,
                               pagina = ViewBag.PaginaActual - 1,
                               tamañoPagina = ViewBag.TamañoPagina,
                               fechaDesde = ViewBag.FechaDesde,
                               fechaHasta =  ViewBag.FechaHasta
                           })">
                                Anterior
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Anterior</span>
                        }
                    </li>

                    @for (int i = inicio; i <= fin; i++)
                    {
                        <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                               rubroTypeId = ViewBag.FiltroRubroId,
                               cuentaId = ViewBag.FiltroCuentaId,
                               pagina = i,
                               tamañoPagina = ViewBag.TamañoPagina,
                               fechaDesde = ViewBag.FechaDesde,
                               fechaHasta =  ViewBag.FechaHasta
                           })">
                                @i
                            </a>
                        </li>
                    }
                    <!-- Botón Siguiente -->
                    <li class="page-item @(ViewBag.PaginaActual >= totalPaginas ? "disabled" : "")">
                        @if (ViewBag.PaginaActual < totalPaginas)
                        {
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                               rubroTypeId = ViewBag.FiltroRubroId,
                               cuentaId = ViewBag.FiltroCuentaId,
                               pagina = ViewBag.PaginaActual + 1,
                               tamañoPagina = ViewBag.TamañoPagina,
                               fechaDesde = ViewBag.FechaDesde,
                               fechaHasta =  ViewBag.FechaHasta
                           })">
                                Siguiente
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Siguiente</span>
                        }
                    </li>
                </ul>
            </nav>
        </div>
    </section>
</main>



<!-- Modal de Creación -->
<div class="modal fade" id="modalCrearGastoId" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-success">
            <!-- Header verde -->
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Gasto
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Gasto" asp-action="Create" method="post">
                <div class="modal-body">

                    <!-- Fecha (hoy por defecto) -->
                    <div class="mb-3">
                        <label for="crearFecha" class="form-label">Fecha</label>
                        <input type="date" id="crearFecha" name="Fecha"
                               class="form-control" required
                               value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <!-- Periodo de Imputación -->
                    <div class="mb-3">
                        <label for="crearPeriodoId" class="form-label">Período de Imputación</label>
                        <select id="crearPeriodoId" name="PeriodoId" class="form-select" required>
                            <option value="">Seleccionar período...</option>
                            @if (periodos != null)
                            {
                                foreach (var periodo in periodos)
                                {
                                    <option value="@periodo.Id">@FormatPeriodo(periodo.Fecha)</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Monto -->
                    <div class="mb-3">
                        <label for="crearMonto" class="form-label">Monto</label>
                        <input type="number" step="0.01" id="crearMonto"
                               name="Monto" class="form-control" required
                               placeholder="$ 0.00" />
                    </div>

                    <!-- Rubro -->
                    <div class="mb-3">
                        <label for="crearRubroId" class="form-label">Rubro</label>
                        <select id="crearRubroId" name="RubroTypeId"
                                class="form-select" required>
                            <option value="">Seleccionar rubro...</option>
                            @if (rubros != null)
                            {
                                foreach (var rubro in rubros)
                                {
                                    <option value="@rubro.Id">@rubro.nombreRubro</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Cuenta -->
                    <div class="mb-3">
                        <label for="crearCuentaId" class="form-label">Cuenta</label>
                        <select id="crearCuentaId" name="CuentaId"
                                class="form-select" required>
                            <option value="">Seleccionar cuenta...</option>
                            @if (ViewBag.Cuentas != null)
                            {
                                foreach (var cuenta in ViewBag.Cuentas)
                                {
                                    <option value="@cuenta.Id">@cuenta.nombreCuenta</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Nota -->
                    <div class="mb-3">
                        <label for="crearNota" class="form-label">Nota</label>
                        <div class="input-group">
                            <textarea id="crearNota"
                                      name="Nota"
                                      class="form-control"
                                      rows="1"
                                      placeholder="Descripción..."></textarea>
                        </div>
                    </div>

                    <input type="hidden" id="forzarSaldoNegativo"
                           name="ForceNegativeBalance" value="false" />

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-success" onclick="crearGasto()">
                        <i class="bi bi-check-circle me-1"></i>Crear Gasto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Edición -->
<div class="modal fade" id="modalEditarGastoId" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form action="@Url.Action("Edit","Gasto")" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>Editar Gasto
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="editGastoId" name="Id" />

                    <!-- Fecha -->
                    <div class="mb-3">
                        <label for="editFecha" class="form-label">Fecha</label>
                        <input type="date" id="editFecha" name="Fecha"
                               class="form-control" required />
                    </div>

                    <!-- Periodo de Imputación -->
                    <div class="mb-3">
                        <label for="editPeriodoId" class="form-label">Periodo de Imputación</label>
                        <select id="editPeriodoId" name="PeriodoId" class="form-select" required>
                            <option value="">Seleccionar Periodo...</option>
                            @if (ViewBag.Periodos != null)
                            {
                                foreach (var periodo in ViewBag.Periodos)
                                {
                                    <option value="@periodo.Id">@FormatPeriodo(periodo.Fecha)</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Monto -->
                    <div class="mb-3">
                        <label for="editMonto" class="form-label">Monto</label>
                        <input type="number" step="0.01" id="editMonto"
                               name="Monto" class="form-control" required />
                    </div>

                    <!-- Rubro -->
                    <div class="mb-3">
                        <label for="editRubroId" class="form-label">Rubro</label>
                        <select id="editRubroId" name="RubroTypeId"
                                class="form-select" required>
                            <option value="">Seleccionar rubro...</option>
                            @if (ViewBag.Rubros != null)
                            {
                                foreach (var rubro in ViewBag.Rubros)
                                {
                                    <option value="@rubro.Id">@rubro.nombreRubro</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Cuenta -->
                    <div class="mb-3">
                        <label for="editCuentaId" class="form-label">Cuenta</label>
                        <select id="editCuentaId" name="CuentaId"
                                class="form-select" required>
                            <option value="">Seleccionar cuenta...</option>
                            @if (ViewBag.Cuentas != null)
                            {
                                foreach (var cuenta in ViewBag.Cuentas)
                                {
                                    <option value="@cuenta.Id">@cuenta.nombreCuenta</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Nota -->
                    <div class="mb-3">
                        <label for="editNota" class="form-label">Nota</label>
                        <textarea id="editNota" name="Nota"
                                  class="form-control" rows="1"></textarea>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminarGastoId" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("DeleteGasto","Gasto")" method="post">
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="deleteGastoId" name="gastoId" />

                    <!-- Mensaje de confirmación -->
                    <div class="text-center">
                        <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">¿Estás seguro de eliminar este gasto?</h5>
                        <p class="text-muted">
                            Esta acción no se puede deshacer. El gasto será eliminado permanentemente.
                        </p>

                        <!-- Información del gasto a eliminar -->
                        <div class="alert alert-light mt-3 text-start" id="deleteGastoInfo">
                            <div class="row">
                                <div class="col-6 mt-2"><strong>Fecha:</strong> <span id="deleteGastoFecha">-</span></div>
                                <div class="col-6 mt-2"><strong>Monto:</strong> <span id="deleteGastoMonto">-</span></div>
                                <div class="col-6 mt-2"><strong>Rubro:</strong> <span id="deleteGastoRubro">-</span></div>
                                <div class="col-6 mt-2"><strong>Cuenta:</strong> <span id="deleteCuenta">-</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Saldo Insuficiente -->
<div class="modal fade" id="modalSaldoInsuficiente" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-warning">

            <!-- Header amarillo -->
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Saldo insuficiente
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="mensajeSaldo" class="mb-0">
                    La cuenta no tiene saldo suficiente.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button" class="btn btn-danger"
                        onclick="confirmarGastoConSaldoNegativo()">
                    <i class="bi bi-check-circle me-1"></i>
                    Realizar gasto igual
                </button>
            </div>

        </div>
    </div>
</div>


<script>
   
    function actualizarRubrosPorFecha(fechaInputId, rubroSelectId, rubroSeleccionadoId = null) {
        const date = document.getElementById(fechaInputId).value;
        if (!date) return;

        fetch('@Url.Action("GetCategoriesbyDate", "Budget", new { area = "Accounting" })?date=' + date)
            .then(res => res.json())
            .then(data => {
                const select = document.getElementById(rubroSelectId);
                select.innerHTML = '<option value="">Seleccionar rubro...</option>';

                data.forEach(r => {
                    // Verificamos si este es el rubro que debe estar seleccionado
                    const isSelected = (rubroSeleccionadoId && r.id == rubroSeleccionadoId) ? 'selected' : '';
                    select.innerHTML += `<option value="${r.id}" ${isSelected}>${r.nombreRubro}</option>`;
                });
            })
            .catch(err => console.error("Error cargando rubros:", err));
    }

    // --- MODAL CREACIÓN ---

    function AbrirModalCrearGasto() {
        document.getElementById('crearFecha').value = new Date().toISOString().split('T')[0];
        document.getElementById('crearMonto').value = "";
        document.getElementById('crearNota').value = "";
        document.getElementById('crearRubroId').value = "";
        document.getElementById('crearPeriodoId').value = "";
        document.getElementById('crearCuentaId').value = "";

        // Al abrir, cargamos los rubros para la fecha por defecto (hoy)
        actualizarRubrosPorFecha("crearFecha", "crearRubroId");

        const modal = new bootstrap.Modal(document.getElementById('modalCrearGastoId'));
        modal.show();
    }

    // Listener para cambios de fecha en creación
    document.getElementById("crearFecha").addEventListener("change", () => {
        actualizarRubrosPorFecha("crearFecha", "crearRubroId");
    });

    // --- MODAL EDICIÓN ---

    function AbrirModalEditarGasto(id, fecha, monto, nota, rubroId, cuentaId, periodoId) {
        document.getElementById('editGastoId').value = id;
        document.getElementById('editFecha').value = fecha;
        document.getElementById('editMonto').value = monto;
        document.getElementById('editNota').value = nota;
        document.getElementById('editCuentaId').value = cuentaId;
        document.getElementById('editPeriodoId').value = periodoId;

        // Cargamos rubros específicos de esa fecha y seleccionamos el actual
        actualizarRubrosPorFecha("editFecha", "editRubroId", rubroId);

        const modal = new bootstrap.Modal(document.getElementById('modalEditarGastoId'));
        modal.show();
    }

    // Listener para cambios de fecha en edición
    document.getElementById("editFecha").addEventListener("change", () => {
        actualizarRubrosPorFecha("editFecha", "editRubroId");
    });

    // --- ELIMINACIÓN Y FILTROS ---

    function AbrirModalEliminarGasto(id, fecha, monto, rubro, cuenta) {
        document.getElementById('deleteGastoId').value = id;
        document.getElementById('deleteGastoFecha').textContent = fecha;
        document.getElementById('deleteGastoMonto').textContent = '$' + parseFloat(monto).toFixed(2);
        document.getElementById('deleteGastoRubro').textContent = rubro;
        document.getElementById('deleteCuenta').textContent = cuenta;

        const modal = new bootstrap.Modal(document.getElementById('modalEliminarGastoId'));
        modal.show();
    }

    function limpiarFiltrosGasto() {
        window.location.href = '@Url.Action("Index", "Diary")';
    }

    function aplicarFiltros() {
        const rubroId = document.getElementById('rubroFilter').value;
        const cuentaId = document.getElementById('cuentaFilter').value;
        const fechaDesde = document.getElementById('fechaDesde')?.value;
        const fechaHasta = document.getElementById('fechaHasta')?.value;

        let url = '@Url.Action("Index", "Diary")';
        const params = new URLSearchParams();

        if (rubroId) params.append('rubroTypeId', rubroId);
        if (cuentaId) params.append('cuentaId', cuentaId);
        if (fechaDesde) params.append('fechaDesde', fechaDesde);
        if (fechaHasta) params.append('fechaHasta', fechaHasta);

        params.append('pagina', 1);
        params.append('tamañoPagina', @ViewBag.TamañoPagina);

        if (params.toString()) {
            url += '?' + params.toString();
        }

        window.location.href = url;
    }

    // --- LÓGICA DE PERSISTENCIA (AJAX CREAR) ---

    function crearGasto() {
        const form = document.querySelector('#modalCrearGastoId form');

        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        const formData = new FormData(form);
        fetch('@Url.Action("Create", "Gasto", new { area = "Accounting" })', {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(res => res.json())
        .then(data => {
            if (data.confirmationRequired) {
                mostrarModalSaldo(data.mensaje);
                return;
            }
            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
            }
        })
        .catch(err => {
            console.error(err);
            alert('Error al crear gasto');
        });
    }

    function mostrarModalSaldo(mensaje) {
        document.getElementById('mensajeSaldo').innerText = mensaje;
        const modal = new bootstrap.Modal(document.getElementById('modalSaldoInsuficiente'));
        modal.show();
    }

    function confirmarGastoConSaldoNegativo() {
        document.getElementById('forzarSaldoNegativo').value = "true";
        const modal = bootstrap.Modal.getInstance(document.getElementById('modalSaldoInsuficiente'));
        modal.hide();
        crearGasto();
    }

    // --- INICIALIZACIÓN ---

    document.addEventListener("DOMContentLoaded", () => {
        // Carga inicial para el campo de creación si hay una fecha por defecto
        actualizarRubrosPorFecha("crearFecha", "crearRubroId");
    });

    const modalCrear = document.getElementById('modalCrearGastoId');
    modalCrear.addEventListener('shown.bs.modal', function () {
        const fechaInput = document.getElementById('crearFecha');
        fechaInput.focus();
        if (fechaInput.showPicker) {
            fechaInput.showPicker();
        }
    });

</script>
