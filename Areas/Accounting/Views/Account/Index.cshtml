@using PresupuestoMVC.Models.Entities
@using PresupuestoMVC.Models.DTOs
@using PresupuestoMVC.Enums;
@using System.Globalization
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var accounts = ViewBag.Accounts as IEnumerable<CuentaResponseDto>;
    // var roles = ViewBag.Roles;
    // var meses = ViewBag.Meses as IEnumerable<int>;
    // var anios = ViewBag.Anios as IEnumerable<int>;
    // var paginacion = ViewBag.Paginacion as PaginacionRespuestaDto<RubroResponseDto>;

    // int totalPaginas = (int)Math.Ceiling((double)paginacion.TotalRegistros / ViewBag.TamañoPagina);
    // int inicio = Math.Max(1, ViewBag.PaginaActual - 2);
    // int fin = Math.Min(totalPaginas, ViewBag.PaginaActual + 2);
}
<!-- Header -->
<header class="oca-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold">
                    <i class="bi bi-building me-3"></i>
                    Cuentas
                </h1>
                <p class="lead mb-0">Sistema de control de cuentas</p>
            </div>
        </div>
    </div>
</header>

<div class="container">

    <!-- Filtros -->
    <section class="filter-section">
        <div class="row align-items-end">

            <div class="col-md-2">
                <div class="d-flex gap-2 align-items-end">
                    <button class="btn btn-success" id="btnNuevaCuenta"
                            onclick="abrirModalCrear()">
                        <i class="bi bi-plus-circle"></i> Nueva Cuenta
                    </button>
                </div>
            </div>

            <div class="col-md-2">
                <div class="d-flex gap-2 align-items-end">
                    <button class="btn btn-warning text-white" id="btnNuevoIngreso"
                            onclick="abrirModalIngresar()">
                        <i class="bi bi-arrow-down"></i> Nuevo Ingreso
                    </button>
                </div>
            </div>

            <div class="col-md-2">
                <div class="d-flex gap-2 align-items-end">
                    <button class="btn btn-secondary" id="btnNuevaTranfere"
                            onclick="abrirModalTransferir()">
                        <i class="bi bi-arrow-up"></i> Transferir
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- Grilla de Cuenta -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-oca">
            <thead>
                <tr>
                    <th scope="col">Cuenta</th>
                    <th scope="col">Monto</th>
                    <th scope="col">Acciones</th>
                </tr>
            </thead>
            <tbody id="accountTableBody">
                @if (accounts != null && accounts.Any())
                {
                    foreach (var account in accounts)
                    {
                        <tr>
                            <td data-account="account">
                                @account.nombreCuenta
                            </td>
                            <td data-amount="amount">
                                @account.SaldoActual.ToString("C0", new CultureInfo("es-AR"))
                            </td>
                            <td>
@*                                 <button class="btn btn-sm btn-primary me-1 btn-edit-user"
                                        onclick="abrirModalEditar(
                                        '@account.Id',
                                        '@account.nombreCuenta',
                                    )">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
 *@
                                <button class="btn btn-sm btn-danger btn-delete-user"
                                        onclick="abrirModalEliminar(
                                        '@account.Id',
                                        '@account.nombreCuenta',
                                    )">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No hay cuentas para mostrar
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>

<!-- Modal de Creación -->
<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-success">
            <!-- Header verde -->
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Nueva Cuenta
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("CreateAccount")" method="post">
                <div class="modal-body">

                    <!-- Cuenta -->
                    <div class="mb-3">
                        <label for="createAccount" class="form-label">Nombre de la cuenta</label>
                        <div class="input-group">
                            <input type="text" id="createAccountId" name="AccountName"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="Banco Macro"
                                   required />
                        </div>
                    </div>

                    <!-- monto -->
                    <div class="mb-3">
                        <label for="InitialBalance" class="form-label">Monto</label>
                        <div class="input-group">
                            <input type="text" id="InitialBalanceId" name="InitialBalance"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="$1000"
                                   required />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Crear Cuenta
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("Delete")" method="post">
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="deleteUserId" name="id" />

                    <!-- Mensaje de confirmación -->
                    <div class="text-center">
                        <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">¿Estás seguro de eliminar el usuario?</h5>
                        <p class="text-muted">
                            Esta acción no se puede deshacer. El usuario será eliminado permanentemente.
                        </p>

                        <!-- Información del usuario a eliminar -->
                        <div class="alert alert-light mt-3 text-start" id="deleteRubroInfo">
                            <div class="row">
                                <div class="col-6"><strong>Usuario:</strong> <span id="deleteUsernameId">-</span></div>
                                <div class="col-6 mt-2"><strong>Rol:</strong> <span id="deleteRol">-</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Ingresar -->
<div class="modal fade" id="modalIngresar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-down"></i> Nuevo Ingreso
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("CreateIncome")" method="post">
                <div class="modal-body">

                    <!-- Cuenta -->
                    <div class="mb-3">
                        <label for="" class="form-label">Cuenta</label>
                        <select id="accountId" name="Id"
                                class="form-select" required>
                            <option value="">Seleccionar cuenta...</option>
                            @if (accounts != null)
                            {
                                foreach (var account in accounts)
                                {
                                    <option value="@account.Id">@account.nombreCuenta</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- monto -->
                    <div class="mb-3">
                        <label for="InitialBalance" class="form-label">Monto</label>
                        <div class="input-group">
                            <input type="text" id="IngresarMonto" name="Amount"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="$1000"
                                   required />
                        </div>
                    </div>

                    <!-- Nota -->
                    <div class="mb-3">
                        <label for="crearNota" class="form-label">Nota</label>
                        <div class="input-group">
                            <textarea id="crearNota"
                                      name="Note"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Descripción..."></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn bg-warning ">
                            <i class="bi bi-check-circle me-1"></i>Confirmar Ingreso
                        </button>
                    </div>  
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Transferir -->
<div class="modal fade" id="modalTransferir" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-up"></i> Transferir
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("CreateTransfer")" method="post">
                <div class="modal-body">

                    <!-- Cuenta Origen-->
                    <div class="mb-3">
                        <label for="" class="form-label">Cuenta Origen</label>
                        <select id="accountOriginId" name="AccountOriginId"
                                class="form-select" required>
                            <option value="">Seleccionar cuenta...</option>
                            @if (accounts != null)
                            {
                                foreach (var account in accounts)
                                {
                                    <option value="@account.Id">@account.nombreCuenta</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Cuenta Destino-->
                    <div class="mb-3">
                        <label for="" class="form-label">Cuenta Destino</label>
                        <select id="accountDestinationId" name="AccountDestinationId"
                                class="form-select" required>
                            <option value="">Seleccionar cuenta...</option>
                            @if (accounts != null)
                            {
                                foreach (var account in accounts)
                                {
                                    <option value="@account.Id">@account.nombreCuenta</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- monto -->
                    <div class="mb-3">
                        <label for="InitialBalance" class="form-label">Monto</label>
                        <div class="input-group">
                            <input type="text" id="IncomeAmountTransfer" name="Amount"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="$1000"
                                   required />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-secondary">
                            <i class="bi bi-check-circle me-1"></i> Transferir
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>

    function abrirModalCrear() {
        document.getElementById('createAccountId');
        document.getElementById('InitialBalanceId');

        const modal = new bootstrap.Modal(document.getElementById('modalCrear'));
        modal.show();
    }

    function abrirModalEliminar(id, user, rol) {
        // Llenar formulario
        document.getElementById('deleteUserId').value = id;
        document.getElementById('deleteUsernameId').innerText = user;
        document.getElementById('deleteRol').innerText = rol;

        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        modal.show();
    }

    function abrirModalIngresar() {
        document.getElementById("accountId").value = "";
        document.getElementById("IngresarMonto").value = "";
        document.getElementById("crearNota").value = "";

        const modal = new bootstrap.Modal(document.getElementById('modalIngresar'));
        modal.show();
    }
    function abrirModalTransferir(){
        document.getElementById("accountOriginId").value = "";
        document.getElementById("accountDestinationId").value = "";
        document.getElementById("IncomeAmountTransfer").value = "";

        const modal = new bootstrap.Modal(document.getElementById('modalTransferir'));
        modal.show();
    }
