                    <button class="btn btn-outline-success" id="btnNuevoRubro"
                            onclick="abrirModalCrear('',false)">
                        <i class="bi bi-plus-circle"></i>Nuevo Rubro
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- Grilla de Rubros -->
    <div class="table-responsive">
        <table class="table  table-hover table-oca">
            <thead>
                <tr>
                    <th>Rubro</th>
                    <th class="text-end pe-3">Acciones</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var category in categories.Where(c => c.Id != 34 && c.Id != 35))
                {
                    var collapseId = $"subrubros-{category.Id}";

                    <!-- Rubro padre -->
                    <tr class="rubro-row">
                        <td >
                            @if (category.SubCategories.Any())
                            {
                                <button class="btn btn-sm btn-link p-0 me-2"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="false">
                                    <i class="bi bi-caret-right-fill"></i>
                                </button>
                            }

                            <strong>@category.nombreRubro</strong>
                        </td>
                        <td class="text-end pe-3">
                            <button class="btn btn-outline-success" id="btnNuevoSubRubro"
                                    onclick="abrirModalCrear(@category.Id, true)">
                                <i class="bi bi-plus-circle"></i>
                            </button>
                            <button class="btn btn-sm btn-danger"
                                    onclick="abrirModalEliminar('@category.Id', '@category.nombreRubro')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>

                    <!-- Subrubros -->
                    @if (category.SubCategories.Any())
                    {
                        <tr class="collapse subrubro-row" id="@collapseId">
                            <td colspan="2" class="p-0">
                                <table class="table mb-0 table-sm">
                                    <tbody>
                                        @foreach (var sub in category.SubCategories)
                                        {
                                            <tr>
                                                <td class="ps-5">
                                                    <i class="bi bi-arrow-return-right me-2 text-muted"></i>
                                                    @sub.nombreRubro
                                                </td>
                                                <td class="text-end pe-3">
                                                    <button class="btn btn-sm btn-danger"
                                                            onclick="abrirModalEliminar('@sub.Id', '@sub.nombreRubro')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>

    <!-- Paginación -->
    @*     <nav aria-label="Paginación de rubro">
