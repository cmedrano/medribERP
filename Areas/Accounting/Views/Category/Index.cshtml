<!-- Modal de Creación -->
<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog erp-modal">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="erp-modal-header">
                <h5 class="erp-modal-title" id="modalArticuloTitle">
                    <i class="bi bi-box"></i> Nuevo Rubro
                </h5>
                <button class="erp-modal-close"
                        type="button"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("CreateCategory")" method="post">
                <div class="modal-body">

                    <!-- Rubro -->
                    <div class="mb-3">
                        <label for="createCategory" class="form-label">Rubro</label>
                        <div class="input-group">
                            <input type="string" id="createCategory" name="Rubro"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="ej.: Seguridad"
                                   required />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-soft btn-pill"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit"
                                class="btn btn-primary btn-pill"
                            <i class="bi bi-check-circle me-1"></i>
                            Crear Rubro
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Creación SubCategory-->
<div class="modal fade" id="modalCrearSubCategory" tabindex="-1">
    <div class="modal-dialog erp-modal">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="erp-modal-header">
                <h5 class="erp-modal-title">
                    <i class="bi bi-box"></i>Nuevo Sub Rubro
                </h5>

                <button class="erp-modal-close"
                        type="button"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("CreateCategory")" method="post">
                <div class="modal-body">

                    <!-- Rubro -->
                    <div class="mb-3">
                        <div class="input-group">
                            <input type="hidden" id="categoryId" name="RubroPadreId"
                                   class="form-control"
                                   min="0"
                                   step="1" />
                        </div>
                    </div>

                    <!-- SubRubro -->
                    <div class="mb-3">
                        <label for="createSubCategory" class="form-label">Sub Rubro</label>
                        <div class="input-group">
                            <input type="text" id="createSubCategory" name="SubCategory"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="ej.: Informatica"
                                   required />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft btn-pill"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary btn-pill">
                            <i class="bi bi-check-circle me-1"></i>Crear Sub Rubro
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form action="@Url.Action("DeleteCategory")" method="post">
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="deleteCategoryId" name="Id" />

                    <!-- Mensaje de confirmación -->
                    <div class="text-center">
                        <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">¿Estás seguro de eliminar el rubro/sub rubro?</h5>
                        <p class="text-muted">
                            Esta acción no se puede deshacer. El rubro y/o sub rubro será eliminado permanentemente.
                        </p>

                        <!-- Información del rubro a eliminar -->
                        <div class="alert alert-light mt-3 text-start" id="deleteCategoryInfo">
                            <div class="row">
                                @* <div class="col-6"><strong>id:</strong> <span id="deleteCategory">-</span></div> *@
                                <div class="col-6"><strong>Rubro:</strong> <span id="deleteCategoryName">-</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

