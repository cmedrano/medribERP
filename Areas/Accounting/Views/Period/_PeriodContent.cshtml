@using PresupuestoMVC.Models.DTOs
@using System.Globalization
@using PresupuestoMVC.Models.Entities

@{
    var periodos = ViewBag.Periodos as IEnumerable<PeriodResponseDto>;
    var years = ViewBag.Years as IEnumerable<Year>;
    var months = ViewBag.Months as IEnumerable<Month>;
    Func<DateTime, string> FormatPeriodo = (fecha) =>
        {
         var cultureInfo = new CultureInfo("es-ES");
         string monthName = cultureInfo.DateTimeFormat.GetMonthName(fecha.Month);
         string capitalizedMonth = string.Concat(monthName[0].ToString().ToUpper(), monthName.AsSpan(1));
         return $"{capitalizedMonth} {fecha.Year}";
        };
}

<header class="oca-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold">
                    <i class="bi bi-building me-3"></i>
                    Periodos
                </h1>
            </div>
        </div>
    </div>
</header>

<div class="container">
    <section class="filter-section">
        <div class="row align-items-end">
            <div class="col-md-2">
                <div class="d-flex gap-2 align-items-end">
                    <button class="btn btn-success" id="btnNuevoPeriodo" onclick="abrirModalCrearPeriodo()">
                        <i class="bi bi-plus-circle"></i> Nuevo Periodo
                    </button>
                </div>
            </div>
        </div>
    </section>

    <div class="table-responsive">
        <table class="table table-striped table-hover table-oca">
            <thead>
                <tr>
                    <th scope="col">Periodo de imputación</th>
                    <th scope="col">Valor Presupuestado</th>
                    <th scope="col">Total Gastos</th>
                    <th scope="col" class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody id="periodTableBody">
                @if (periodos != null && periodos.Any())
                {
                    foreach (var periodo in periodos)
                    {
                        <tr>
                            <td class="text-capitalize">@FormatPeriodo(periodo.Fecha)</td>
                            <td>@periodo.ValorPresupuestado.ToString("C2")</td>
                            <td>@periodo.TotalGastos.ToString("C2")</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-link text-success p-0"
                                        onclick="abrirModalEditar('@periodo.Id', '@periodo.Fecha.Year', '@periodo.Fecha.Month', '@periodo.ValorPresupuestado')">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No hay períodos para mostrar</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="modalTitleText">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Periodo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="formPeriodo" action="@Url.Action("Create")" method="post">
                <input type="hidden" id="EditPeriodoId" name="Id" value="0" />

                <div class="modal-body">
                    <div class="mb-3">
                        <label for="YearId" class="form-label">Año</label>
                        <select id="YearId" name="YearId" class="form-select" required>
                            <option value="">Seleccionar año...</option>
                            @if (years != null)
                            {
                                foreach (var y in years)
                                {
                                    <option value="@y.Id">@y.YearValue</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="MonthId" class="form-label">Mes</label>
                        <select id="MonthId" name="MonthId" class="form-select @(ViewData.ModelState["MonthId"]?.Errors.Count > 0 ? "is-invalid" : "")" required>
                            <option value="">Seleccionar mes...</option>
                            @if (months != null)
                            {
                                var culture = new System.Globalization.CultureInfo("es-ES");
                                foreach (var m in months)
                                {
                                    string monthName = culture.DateTimeFormat.GetMonthName(m.MonthNumber);
                                    string capitalizedMonth = char.ToUpper(monthName[0]) + monthName.Substring(1);
                                    <option value="@m.Id">@capitalizedMonth</option>
                                }
                            }
                        </select>
                        <span id="error-duplicado" class="text-danger small" style="display:none;">
                            Este periodo de imputación ya tiene un valor presupuestado.
                        </span>
                        @if (ViewData.ModelState["MonthId"]?.Errors.Count > 0)
                        {
                            <span class="text-danger small">@ViewData.ModelState["MonthId"].Errors[0].ErrorMessage</span>
                        }
                    </div>

                    <div class="mb-3">
                        <label for="ValorPresupuestado" class="form-label">Valor Presupuestado</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" id="ValorPresupuestado" name="ValorPresupuestado" class="form-control" min="0" step="0.01" required />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="btnGuardar" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i>Crear Periodo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>