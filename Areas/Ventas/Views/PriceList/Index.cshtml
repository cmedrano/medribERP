@model IEnumerable<PresupuestoMVC.Models.Entities.PriceList>
@using PresupuestoMVC.Models
@using PresupuestoMVC.Models.Entities

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Lista de precios";
    
    var paginacion = ViewBag.Paginacion as PaginatedResult<PriceList>;
    int totalPaginas = paginacion.TotalPages;
    int inicio = Math.Max(1, paginacion.PageNumber - 2);
    int fin = Math.Min(totalPaginas, paginacion.PageNumber + 2);
}

<main class="flex-grow-1 container-main">
    <!-- Header -->
    <div class="topbar">
        <form method="get" asp-action="Index" class="searchbox">
            <div>
                <i class="bi bi-search"></i>
                <input class="form-control"
                       type="text"
                       name="searchNombre"
                       value="@ViewData["SearchNombre"]"
                       placeholder="Buscar lista..." />
            </div>
        </form>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success-soft" onclick="abrirModalLista(true)"><i class=" bi bi-plus-lg me-2" id="btnNuevoGasto"></i>Nueva lista</button>
        </div>
    </div>
    <div class="page-head">
        <div>
            <h1 class="page-title">@ViewData["Title"]</h1>
            <p class="page-subtitle">Gestión de lista de precios. Mostrando @paginacion.Items.Count() de @paginacion.TotalCount</p>
        </div>
    </div>

    <!-- informacion util rapida -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-currency-dollar"></i></div>
                <div class="metric-label">Cantidad total de lista de precios</div>
                <div class="metric-value">@Model.Count()</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-toggle-on"></i></div>
                <div class="metric-label">Lista de precios activos</div>
                <div class="metric-value">@Model.Count(x => x.Activo)</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-credit-card-2-front"></i></div>
                <div class="metric-label">Lista principal</div>
                <div class="metric-value">Minorista</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-tags"></i></div>
                <div class="metric-label">Lista menos utilizada</div>
                <div class="metric-value">Distribuidor</div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <section class="erp-card table-card">
       <div class="table-tools">
           <div>
               <h2 class="section-title">Listas registradas</h2>
               <p class="section-subtitle">
                   Mostrando @paginacion.Items.Count() de @paginacion.TotalCount
               </p>
           </div>
       </div>
        <div class="card-body p-0">
            <table class="table table-modern table-hover align-middle">
                <thead class="custom-header text-white">
                    <tr>
                       <th class="form-label small">NOMBRE</th>
                       <th class="form-label small">DESCRIPCIÓN</th>
                        <th class="form-label small" >FECHA CREACIÓN</th>
                        <th class="form-label small">ACTIVO</th>
                        <th class="form-label small text-end">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (paginacion != null && paginacion.Items.Any())
                    {
                        foreach (var item in paginacion.Items)
                        {
                            <tr>
                                <td><span class="badge-soft badge-cuenta">@item.Nombre</span></td>
                                <td class="fw-semibold">@item.Descripcion</td>
                                <td><span class="date-pill"><i class="bi bi-calendar3"></i>@item.CreatedAt.ToShortDateString()</span></td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge-soft badge-success">
                                            <i class="bi bi-circle-fill text-success"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft badge-danger">
                                            <i class="bi bi-circle-fill text-secondary"></i>
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                <button type="button"
                                        class="icon-btn"
                                        title="Ver"
                                        onclick="abrirModalLista(false, '@item.Id', '@item.Nombre','@item.Descripcion', true)">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button type="button"
                                        class="icon-btn"
                                        title="Editar"
                                        onclick="abrirModalLista(
                                            false,
                                            '@item.Id',      
                                            '@item.Nombre',
                                            '@item.Descripcion',
                                            false)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button"
                                        class="icon-btn icon-btn-danger"
                                        title="Eliminar"
                                        onclick="abrirModalEliminar('@item.Id', '@item.Nombre');"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalConfirmarEliminar">
                                    <i class="bi bi-trash text-danger"></i>
                                </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">
                                No hay listas cargadas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer">
            <small class="text-muted">Página @paginacion.PageNumber de @totalPaginas</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <!-- Botón Anterior -->
                    <li class="page-item @(paginacion.PageNumber == 1 ? "disabled" : "")">
                        @if (paginacion.PageNumber > 1)
                        {
                            <a class="page-link" href="@Url.Action("Index", "PriceList", new { Area = "Ventas", pagina = paginacion.PageNumber - 1, tamañoPagina = paginacion.PageSize })">
                                Anterior
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Anterior</span>
                        }
                    </li>

                    @for (int i = inicio; i <= fin; i++)
                    {
                        <li class="page-item @(i == paginacion.PageNumber ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", "PriceList", new { Area = "Ventas", pagina = i, tamañoPagina = paginacion.PageSize })">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Botón Siguiente -->
                    <li class="page-item @(paginacion.PageNumber >= totalPaginas ? "disabled" : "")">
                        @if (paginacion.PageNumber < totalPaginas)
                        {
                            <a class="page-link" href="@Url.Action("Index", "PriceList", new { Area = "Ventas", pagina = paginacion.PageNumber + 1, tamañoPagina = paginacion.PageSize })">
                                Siguiente
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Siguiente</span>
                        }
                    </li>
                </ul>
            </nav>
        </div>
    </section>
</main>

<!-- Modal Lista (Crear/Ver/Editar) -->
<div class="modal fade" id="modalLista" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="erp-modal-header">
                <h5 class="erp-modal-title" id="modalListaTitle">
                    <i class="bi bi-plus-circle me-2"></i>Crear Lista
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formLista" method="post">
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" name="Id" id="ListaId">

                    <div class="row g-4">
                        <div class="col">
                            <div class="row g-3 mb-3">
                                <!-- Nombre -->
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-secondary">NOMBRE</label>
                                    <input type="text" name="Nombre" id="listaNombre" class="form-control bg-light border-0 rounded-3 py-2" required>
                                </div>
                                <!-- Descripcion -->
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-secondary">DESCRIPCIÓN</label>
                                    <input type="text" name="Descripcion" id="listaDescripcion" maxlength="100" class="form-control bg-light border-0 rounded-3 py-2">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pe-4 pb-4 bg-white rounded-bottom-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnSubmitForm"></button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalConfirmarEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 3rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">¿Estás seguro?</h5>
                <p class="text-muted">Se eliminará a <strong id="listaEliminarNombre"></strong></p>
            </div>
            <div class="modal-footer border-0 bg-light d-flex justify-content-center gap-2">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger rounded-pill px-4" id="btnConfirmarEliminar">Sí, Eliminar</button>
            </div>
        </div>
    </div>
</div>

<script>
   function abrirModalLista(
        crear,
        id,
        nombre,
        descripcion,
        soloVer = false) {
        isCreating = crear;
        const btnSubmit = document.getElementById('btnSubmitForm');

        if (crear) {
            // Modo crear
            document.getElementById('modalListaTitle').innerHTML = '<i class="bi bi-plus-circle me-2"></i>Crear Lista';
            document.getElementById('formLista').action = '@Url.Action("Create", "PriceList")';
            document.getElementById('btnSubmitForm').innerText = 'Registrar Lista';
            document.getElementById('formLista').reset();
            btnSubmit.style.display = 'block';

            // Habilitar todos los campos
            document.querySelectorAll('#formLista input, #formLista select').forEach(el => {
                el.disabled = false;
            });
        } else {
            // Modo ver/editar
            document.getElementById('ListaId').value = id;
            document.getElementById('listaNombre').value = nombre;
            document.getElementById('listaDescripcion').value = descripcion || '';

            if (soloVer) {
                document.getElementById('modalListaTitle').innerHTML = '<i class="bi bi-eye me-2"></i>Detalle';
                btnSubmit.style.display = 'none';
            } else {
                document.getElementById('modalListaTitle').innerHTML = '<i class="bi bi-pencil-square me-2"></i>Editar Lista';
                document.getElementById('formLista').action = '@Url.Action("EditList", "PriceList")';
                document.getElementById('btnSubmitForm').innerText = 'Actualizar';
                btnSubmit.style.display = 'block';
            }

            // Aplicar readonly/disabled según soloVer
            document.querySelectorAll('#formLista input, #formLista select').forEach(el => {
                el.disabled = soloVer;
            });
        }

        const modal = new bootstrap.Modal(document.getElementById('modalLista'));
        modal.show();
    }

    function abrirModalEliminar(id, nombre) {
        document.getElementById('listaEliminarNombre').innerText = nombre;
        document.getElementById('btnConfirmarEliminar').onclick = function () {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("DeleteList", "PriceList")';

            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'id';
            input.value = id;

            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        };
    }

</script>

<style>
    .custom-header {
        background: linear-gradient(90deg, #2b6edb, #1e4fbf);
        /* font-size: 1.1rem; */
    }

    table tbody tr:hover {
        background-color: #f5f8ff;
    }

    .card {
        border-radius: 20px;
    }

    .btn-lg {
        border-radius: 12px;
        padding: 10px 25px;
    }
</style>