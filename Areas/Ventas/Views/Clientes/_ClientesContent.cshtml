@using PresupuestoMVC.Models.DTOs
@model PaginacionRespuestaDto<ClienteResponseDTO>
@{
    ViewData["Title"] = "Clientes";
    var priceList = ViewBag.PriceList;
    var currentPage = (int)ViewData["CurrentPage"];
    var searchNombre = (string)ViewData["SearchNombre"];
    var searchFantasia = (string)ViewData["SearchFantasia"];
}

<!-- Header -->
<main class="flex-grow-1 container-main">
    <div class="topbar">
        <div class="searchbox">
            <i class="bi bi-search"></i>
            <input class="form-control" type="text" placeholder="Buscar cleinte ó alias..." />
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-success-soft"
                    onclick="abrirModalCliente(true)">
                <i class=" bi bi-plus-lg me-2" id="btnNuevoCliente"></i>
                Nuevo cliente
            </button>
        </div>
    </div>
    <div class="page-head">
        <div>
            <h1 class="page-title">@ViewData["Title"]</h1>
            <p class="page-subtitle">Administración y gestión integral de clientes</p>
        </div>
    </div>

    <!-- informacion util rapida -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-journal-text"></i></div>
                <div class="metric-label">Agregado este mes</div>
                <div class="metric-value">5</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="metric-label">Inactivos</div>
                <div class="metric-value">1</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-credit-card-2-front"></i></div>
                <div class="metric-label">Categoria mayorista</div>
                <div class="metric-value">2</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="erp-card metric-card">
                <div class="metric-icon"><i class="bi bi-tags"></i></div>
                <div class="metric-label">Promedio por cliente</div>
                <div class="metric-value">$152.658</div>
            </div>
        </div>
    </div>
<!-- Tabla de Clientes -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-tools">
            <div>
                <h2 class="section-title">Clientes registrados</h2>
                <p class="section-subtitle">
                    Mostrando 10 de 101
                </p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">NOMBRE</th>
                        <th class="py-3">TELÉFONO</th>
                        <th class="py-3">EMAIL</th>
                        <th class="py-3">CATEGORÍA</th>
                        <th class="pe-4 py-3 text-end">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Datos.Count > 0)
                    {
                        @foreach (var item in Model.Datos)
                        {
                            <tr>
                                <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                             style="width: 40px; height: 40px; background-color: #dfe3ff;">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.Nombre</div>
                                            <div class="small text-muted">@(item.Fantasia ?? "-")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4">@(item.Telefono ?? "-")</td>
                                <td class="py-4">@(item.Email ?? "-")</td>
                                <td class="py-4">
                                    @if (!string.IsNullOrEmpty(item.Categoria))
                                    {
                                        <span class="badge-soft badge-rubro">@item.Categoria</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="pe-4 py-4 text-end">
                                    <button type="button"
                                            class="icon-btn"
                                            title="Ver"
                                            onclick="abrirModalCliente(false, '@item.Id', '@item.Nombre', '@(item.Telefono ?? "")', '@(item.Domicilio ?? "")', '@(item.Localidad ?? "")', '@(item.Provincia ?? "")', '@(item.CodigoPostal ?? "")', '@(item.Email ?? "")', '@(item.Celular ?? "")', '@(item.DNI ?? "")', '@(item.CUIT ?? "")', '@(item.Fantasia ?? "")', '@(item.CondicionDeVenta ?? "")', '@(item.Categoria ?? "")', '@item.OperacionesContado.ToString().ToLower()', '@item.InhabilitadoFacturar.ToString().ToLower()', true)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button type="button"
                                            class="icon-btn"
                                            title="Editar"
                                            onclick="abrirModalCliente(false, '@item.Id', '@item.Nombre', '@(item.Telefono ?? "")', '@(item.Domicilio ?? "")', '@(item.Localidad ?? "")', '@(item.Provincia ?? "")', '@(item.CodigoPostal ?? "")', '@(item.Email ?? "")', '@(item.Celular ?? "")', '@(item.DNI ?? "")', '@(item.CUIT ?? "")', '@(item.Fantasia ?? "")', '@(item.CondicionDeVenta ?? "")', '@(item.Categoria ?? "")', '@item.OperacionesContado.ToString().ToLower()', '@item.InhabilitadoFacturar.ToString().ToLower()', false)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button"
                                            class="icon-btn icon-btn-danger"
                                            title="Eliminar"
                                            onclick="abrirModalEliminar('@item.Id', '@item.Nombre');"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalConfirmarEliminar">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                <p class="mt-3">No hay clientes para mostrar</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Paginación -->
        @if (Model.TotalPaginas > 1)
        {
            <div class="table-footer">
                <small class="text-muted">Página 1 de 19</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @if (Model.TieneAnterior)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0);" onclick="cambiarPagina(@(Model.PaginaActual - 1))" style="color: #6f42c1;">
                                    <i class="bi bi-chevron-left"></i> Anterior
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-left"></i> Anterior</span>
                            </li>
                        }

                        @{
                            int inicio = Math.Max(1, Model.PaginaActual - 2);
                            int fin = Math.Min(Model.TotalPaginas, Model.PaginaActual + 2);
                        }

                        @for (int i = inicio; i <= fin; i++)
                        {
                            <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                                <a class="page-link" href="javascript:void(0);" onclick="cambiarPagina(@i)">@i</a>
                            </li>
                        }

                        @if (Model.TieneSiguiente)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0);" onclick="cambiarPagina(@(Model.PaginaActual + 1))" style="color: #6f42c1;">
                                    Siguiente <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Siguiente <i class="bi bi-chevron-right"></i></span>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

    <!-- Modal Cliente (Crear/Ver/Editar) -->
    <div class="modal fade" id="modalCliente" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl erp-modal">

            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="erp-modal-header">

                    <h2 class="erp-modal-title" id="modalClienteTitle"></h2>
                    <button class="erp-modal-close" type="button" data-bs-dismiss="modal" aria-label="Cerrar">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <form id="formCliente" method="post">
                    <div class="modal-body erp-modal-body p-4 bg-white">
                        <input type="hidden" name="Id" id="clienteId">

                        <div class="erp-form-grid">
                            <!-- COLUMNA IZQUIERDA -->
                            <section class="erp-form-section">
                                <!-- Datos Básicos -->
                                <h3 class="erp-form-section-title">DATOS BÁSICOS</h3>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre</label>
                                        <input type="text" name="Nombre" id="clienteNombre" class="form-control" placeholder="Ej. Juan Pérez" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre fantasía</label>
                                        <input type="text" name="Fantasia" id="clienteFantasia" class="form-control" placeholder="Ej. Distribuidora Centro">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Categoría</label>
                                        <select name="Categoria" id="clienteCategoria" class="form-select">
                                            <option value="">Seleccionar...</option>
                                            <option value="Mayorista">Mayorista</option>
                                            <option value="Minorista">Minorista</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Condicíon de venta</label>
                                        <select name="CondicionDeVenta" id="clienteCondicionDeVenta" class="form-select">
                                            <option value="">Seleccionar...</option>
                                            <option value="Contado">Contado</option>
                                            <option value="Cuenta Corriente">Cuenta Corriente</option>
                                        </select>
                                    </div>


                                    <!-- Documentos -->
                                    <div class="col-md-6">
                                        <label class="form-label">Dni</label>
                                        <input type="text" name="DNI" id="clienteDNI" class="form-control" placeholder="00.000.000" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">CUIT</label>
                                        <input type="text" name="CUIT" id="clienteCUIT" class="form-control" placeholder="00-00000000-0">
                                    </div>

                                    <!-- lista de precios-->
                                    <div class="col-md-6">
                                        <h3 class="erp-form-section-title">ASOCIAR LISTA</h3>
                                        <select id="SelectListaId" name="PriceListId"
                                                class="form-select" required>
                                            <option value="">Seleccionar lista...</option>
                                            @if (priceList != null)
                                            {
                                                for (int i = 0; i < priceList.Count; i++)
                                                {
                                                    <option value="@priceList[i].Id">@priceList[i].Nombre</option>
                                                }
                                            }
                                        </select>
                                    </div>

                            </section>

                            <!-- COLUMNA DERECHA -->
                            <section class="erp-form-section">
                                <!-- Contacto/Ubicación -->
                                <h3 class="erp-form-section-title">Contacto y ubicación</h3>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Teléfono</label>
                                        <input type="tel" name="Telefono" id="clienteTelefono" class="form-control" placeholder="Ej. 11 4567 8901" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Celular</label>
                                        <input type="tel" name="Celular" id="clienteCelular" class="form-control" placeholder="Ej. 11 2345 6789">
                                    </div>
                                    @* <div class="col-12">
                                    <label class="form-label small fw-bold text-secondary">EMAIL</label>
                                    <input type="email" name="Email" id="clienteEmail" class="form-control bg-light border-0 rounded-3 py-2">
                                    </div> *@
                                    <!-- En la sección del modal, dentro de la COLUMNA DERECHA, reemplazá el input de EMAIL con este código: -->
                                    <div class="col-12">
                                        <label class="form-label">Email</label>
                                        <input type="email" name="Email" id="clienteEmail" class="form-control" placeholder="cliente@empresa.com">
                                        <div id="emailErrorContainer" class="invalid-feedback mt-2 d-none" style="color: #dc3545; font-size: 0.875rem;">
                                            <i class="bi bi-exclamation-circle me-1"></i><span id="emailErrorMessage"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-secondary">Domicilio</label>
                                        <input type="text" name="Domicilio" id="clienteDomicilio" class="form-control" placeholder="Calle 123">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-secondary">Codigo postal</label>
                                        <input type="text" name="CodigoPostal" id="clienteCodigoPostal" class="form-control" placeholder="1888">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-secondary">Localidad</label>
                                        <select name="Localidad" id="clienteLocalidad" class="form-select">
                                            <option value="">Seleccionar localidad...</option>
                                            <option value="Solano">Solano</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-secondary">Provincia</label>
                                        <input type="text" name="Provincia" id="clienteProvincia" class="form-control" placeholder="Buenos Aires">
                                    </div>
                                </div>

                                <!-- Opciones -->
                                <div class="col-12">
                                    <div class="erp-check-list">
                                        <label class="erp-check" for="clienteOperacionesContado">
                                            <input type="checkbox" name="OperacionesContado" id="clienteOperacionesContado" value="true" />
                                            Operaciones al contado
                                        </label>

                                        <label class="erp-check" for="clienteInhabilitadoFacturar">
                                            <input type="checkbox" name="InhabilitadoFacturar" id="clienteInhabilitadoFacturar" value="true" />
                                            Inhabilitado para facturar
                                        </label>
                                    </div>
                                </div>
                            </section>
                        </div>
                    </div>
                    <div class="erp-modal-footer">
                        <button type="button" class="btn btn-soft btn-pill" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-pill" id="btnSubmitForm"></button>
                    </div>
                </form>
            </div>
            </section>
        </div>
    </div>



    <!-- Modal Confirmar Eliminar -->
    <div class="modal fade" id="modalConfirmarEliminar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">¿Estás seguro?</h5>
                    <p class="text-muted">Se eliminará a <strong id="clienteEliminarNombre"></strong></p>
                </div>
                <div class="modal-footer border-0 bg-light d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4" id="btnConfirmarEliminar">Sí, Eliminar</button>
                </div>
            </div>
        </div>
    </div>
