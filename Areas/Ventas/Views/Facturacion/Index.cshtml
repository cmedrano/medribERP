@using static PresupuestoMVC.Areas.Ventas.Controllers.FacturacionController

@{
    @model FacturacionViewModel

    ViewData["Title"] = "Facturación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">

    <!-- HERO -->
    <div class="card mb-4">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-receipt-cutoff fs-1 text-primary"></i>
                <div>
                    <h1 class="h3 mb-1">Nueva factura</h1>
                    <p class="text-muted mb-0">Facturá a clientes registrados o consumidores finales.</p>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3 mt-md-0">
                <button class="btn btn-outline-secondary">
                    <i class="bi bi-clock-history"></i> Historial
                </button>
                <button class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Nueva
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- MAIN -->
        <div class="col-lg-8">

            <!-- DATOS -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Datos de facturación</h5>
                </div>
                <div class="card-body">

                    <div class="mb-3">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="tipo" checked>
                            <label class="form-check-label">Cliente registrado</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="tipo">
                            <label class="form-check-label">No es cliente</label>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Cliente</label>
                            <select class="form-select">
                                <option>Seleccionar...</option>
                                @foreach (var cliente in Model.Clientes)
                                {
                                    <option value="@cliente.Id">
                                        @cliente.Nombre
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Lista de precios</label>
                            <select class="form-select">
                                @* <option>Mayorista</option>
                                <option>Minorista</option> *@
                                <option>Seleccionar...</option>
                                @if (Model.ListasDePrecio != null && Model.ListasDePrecio.Any())
                                {
                                    foreach (var lista in Model.ListasDePrecio)
                                    {
                                        <option value="@lista.Id">@lista.Nombre</option>
                                    }
                                }
                                else
                                {
                                    <option value="">Sin Lista de Precios</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">CUIT</label>
                            <input class="form-control" />
                        </div>
                    </div>

                </div>
            </div>

            <!-- AGREGAR PRODUCTO -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Agregar artículos</h5>
                </div>
                <div class="card-body">

                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label">Artículo</label>
                            <select class="form-select">
                                <option>Seleccionar...</option>
                                @if (Model.Articulos != null && Model.Articulos.Any())
                                {
                                    foreach (var lista in Model.Articulos)
                                    {
                                        <option value="@lista.Id">@lista.Nombre</option>
                                    }
                                }
                                else
                                {
                                    <option value="">Sin Articulos</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Cantidad</label>
                            <input type="number" class="form-control" value="1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Precio</label>
                            <input class="form-control" value="$ 1200">
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </div>

            <!-- TABLA -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Detalle</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Artículo</th>
                                <th>Cant.</th>
                                <th>Precio</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Yerba 1kg</td>
                                <td>2</td>
                                <td>$1200</td>
                                <td>$2400</td>
                                <td><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Resumen</h5>
                </div>
                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <strong>$4250</strong>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Descuento</span>
                        <strong>$0</strong>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-3">
                        <strong>Total</strong>
                        <strong class="fs-5">$4250</strong>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary">Confirmar</button>
                        <button class="btn btn-outline-secondary">Guardar</button>
                        <button class="btn btn-outline-danger">Cancelar</button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>