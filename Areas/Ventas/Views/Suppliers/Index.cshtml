    <div class="modal-dialog erp-modal">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="erp-modal-header">
                <h5 class="erp-modal-title" id="modalProveedorTitle">
                    <i class="bi bi-box"></i> Editar Proveedor
                </h5>
                <button class="erp-modal-close"
                        type="button"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <form action="@Url.Action("UpdateSupplier")" method="post">

                <div class="modal-body d-flex gap-2 p-4">
                    <div class="w-100 d-flex">
                        <!-- Campo oculto para el ID -->
                        <input type="hidden" id="editProviderId" name="Id" />
                        <div>
                            <!-- Codigo -->
                            <div class="mb-3">
                                <label for="crearProveedor" class="form-label">CODIGO</label>
                                <input type="text"
                                       name="Codigo"
                                       id="editCode"
                                       class="form-control"
                                       placeholder="ABC123" />
                            </div>
                            <!-- Empresa -->
                            <div class="mb-3">
                                <label class="form-label">EMPRESA</label>
                                <input type="text"
                                       name="Empresa"
                                       id="editEmpresa"
                                       class="form-control"
                                       placeholder="Microsoft"
                                       required />
                            </div>
                            <!-- Telefono -->
                            <div class="mb-3">
                                <label class="form-label">TELEFONO</label>
                                <input type="number"
                                       name="Telefono"
                                       id="editTelefono"
                                       class="form-control"
                                       placeholder="1122334455" />
                            </div>
                        </div>
                        <div>
                            <!-- DIreccion -->
                            <div class="mb-3">
                                <label class="form-label">DIRECCION</label>
                                <input type="text"
                                       name="Direccion"
                                       id="editDireccion"
                                       class="form-control"
                                       placeholder="Rivadavia 123" />
                            </div>
                            <!-- Mail -->
                            <div class="mb-3">
                                <label class="form-label">MAIL</label>
                                <input type="text"
                                       name="Mail"
                                       id="editMail"
                                       class="form-control"
                                       placeholder="email@gmail.com" />
                            </div>
                            <!-- Resppnsable -->
                            <div class="mb-3">
                                <label class="form-label">RESPONSABLE</label>
                                <input type="text"
                                       name="Responsable"
                                       id="editResponsable"
                                       class="form-control"
                                       placeholder="Luis" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-soft btn-pill"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="btn btn-primary btn-pill">
                        <i class="bi bi-check-circle me-1"></i>
                         Aceptar
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Modal de Ver -->
<div class="modal fade" id="modalVerProveedor" tabindex="-1">
    <div class="modal-dialog erp-modal">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="erp-modal-header">
                <h5 class="erp-modal-title" id="modalProveedorTitle">
                    <i class="bi bi-box"></i> Detalle Proveedor
                </h5>
                <button class="erp-modal-close"
                        type="button"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

                <div class="modal-body gap-2 p-4">
                    <div class="w-100 d-flex">
                        <!-- Campo oculto para el ID -->
                        <input type="hidden" id="editProviderId" name="Id" />
                        <div>
                            <!-- codigo -->
                            <div class="mb-3">
                                <label for="crearProveedor" class="form-label">CODIGO</label>
                                <input type="text"
                                       name="Code"
                                       id="verCode"
                                       class="form-control"
                                       disabled />
                            </div>
                            <!-- Empresa -->
                            <div class="mb-3">
                                <label class="form-label">EMPRESA</label>
                                <input type="text"
                                       name="Empresa"
                                       id="verEmpresa"
                                       class="form-control"
                                       disabled />
                            </div>
                            <!-- Telefono -->
                            <div class="mb-3">
                                <label class="form-label">TELEFONO</label>
                                <input type="number"
                                       name="Telefono"
                                       id="verTelefono"
                                       class="form-control"
                                       placeholder="1122334455"
                                       disabled />
                            </div>
                        </div>
                        <div>
                            <!-- DIreccion -->
                            <div class="mb-3">
                                <label class="form-label">DIRECCION</label>
                                <input type="text"
                                       name="Direccion"
                                       id="verDireccion"
                                       class="form-control"
                                       placeholder="Rivadavia 123"
                                       disabled />
                            </div>
                            <!-- Mail -->
                            <div class="mb-3">
                                <label class="form-label">MAIL</label>
                                <input type="text"
                                       name="Mail"
                                       id="verMail"
                                       class="form-control"
                                       placeholder="email@gmail.com"
                                       disabled />
                            </div>
                            <!-- Resppnsable -->
                            <div class="mb-3">
                                <label class="form-label">RESPONSABLE</label>
                                <input type="text"
                                       name="Responsable"
                                       id="verResponsable"
                                       class="form-control"
                                       placeholder="Luis"
                                       disabled />
                            </div>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                        class="btn btn-primary btn-pill"
                        data-bs-dismiss="modal">
                      <i class="bi bi-check-circle me-1"></i>
                        Aceptar
                    </button>
                </div>
        </div>
    </div>
</div>


<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminarProveedor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form action="@Url.Action("DeleteSupplier")" method="post">
                <div class="modal-body p-5 text-center">
                    <input type="hidden" id="deleteProviderId" name="id" />
                    <div class="mb-4">
                        <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">¿Estás seguro?</h5>
                    <p class="text-muted">Se eliminará a <strong id="deleteProviderName"></strong></p>
                </div>
                <div class="modal-footer border-0 bg-light d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4" id="btnEliminarMarca">Sí, Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>

    // --- MODAL CREACIÓN --- //
    function AbrirModalCrearProveedor() {
        document.getElementById('crearCode').value = "";
        document.getElementById('crearEmpresa').value = "";
        document.getElementById('crearTelefono').value = "";
        document.getElementById('crearDireccion').value = "";
        document.getElementById('crearMail').value = "";
        document.getElementById('crearResponsable').value = "";

        const modal = new bootstrap.Modal(document.getElementById('modalCrearProveedor'));
        modal.show();
    }

    // --- MODAL EDICION --- //
    function AbrirModalEditarProveedor(id, code, empresa, telefono, direccion, mail, responsable) {
        document.getElementById('editProviderId').value = id;
        document.getElementById('editCode').value = code;
        document.getElementById('editEmpresa').value = empresa;
        document.getElementById('editTelefono').value = telefono;
        document.getElementById('editDireccion').value = direccion;
        document.getElementById('editMail').value = mail;
        document.getElementById('editResponsable').value = responsable;

        const modal = new bootstrap.Modal(document.getElementById('modalEditarProveedor'));
        modal.show();
    }

    // --- MODAL ELIMINAR --- //
    function AbrirModalEliminarProveedor(id, nombre) {
        document.getElementById('deleteProviderId').value = id;
        document.getElementById('deleteProviderName').innerText = nombre;

        const modal = new bootstrap.Modal(document.getElementById('modalEliminarProveedor'));
        modal.show();
    }

    // --- MODAL VER --- //
    function AbrirModalVerProveedor(code, empresa, telefono, direccion, mail, responsable){
        var txtCodigo = document.getElementById("verCode").value = code;
        var txtNombre = document.getElementById("verEmpresa").value = empresa;
        var txtNombre = document.getElementById("verTelefono").value = telefono;
        var txtNombre = document.getElementById("verDireccion").value = direccion;
        var txtNombre = document.getElementById("verMail").value = mail;
        var txtNombre = document.getElementById("verResponsable").value = responsable;

        const modal = new bootstrap.Modal(document.getElementById('modalVerProveedor'));
        modal.show();
    }
</script>