@using PresupuestoMVC.Areas.Ventas.ViewModels.DTOs
@model IEnumerable<ArticuloResponseDTO>
@using PresupuestoMVC.Models
@using PresupuestoMVC.Models.Entities

@{
    var paginacion = ViewBag.Paginacion as PaginatedResult<Articulo>;
    int totalPaginas = paginacion.TotalPages;
    int inicio = Math.Max(1, paginacion.PageNumber - 2);
    int fin = Math.Min(totalPaginas, paginacion.PageNumber + 2);
}
<!-- Tabla de Clientes -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-tools">
            <div>
                <h2 class="section-title">Articulos registrados</h2>
                <p class="section-subtitle">
                    Mostrando @paginacion.Items.Count() de @paginacion.TotalCount
                </p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th class="py-3">CODIGO</th>
                        <th class="py-3">NOMBRE</th>
                        <th class="py-3">UNIDAD DE MEDIDA</th>
                        <th class="py-3">PRECIO DE VENTA</th>
                        <th class="py-3">PRECIO DE COMPRA</th>
                        @* <th class="py-3">ACTIVO</th> *@
                        <th class="py-3 text-end">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (paginacion != null && paginacion.Items.Any())
                    {
                        foreach (var item in paginacion.Items)
                        {
                            <tr>
                                @* <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width: 40px; height: 40px; background-color: #fd7e14;">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                    </div>
                                </td> *@
                                <td><span class="badge-soft badge-cuenta">@(item.Codigo ?? "-")</span></td>
                                <td class="py-3">@(item.Nombre ?? "-")</td>
                                <td><span class="badge-soft badge-rubro">@(item.UnidadMedida ?? "-")</span></td>
                                <td><span class="py-3">@(item.SalePrice?.ToString() ?? "-")</span> $</td>
                                <td><span class="py-3">@(item.PurchasePrice?.ToString() ?? "-")</span> $</td>
                                @* <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge-soft badge-success">
                                            <i class="bi bi-circle-fill text-success"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft badge-danger">
                                            <i class="bi bi-circle-fill text-secondary"></i>
                                        </span>
                                    }
                                </td> *@
                                <td class="pe-3 py-3 text-end">
                                    <button type="button"
                                            class="icon-btn"
                                            title="Ver"
                                            onclick="abrirModalArticulo(
                                            false,
                                            '@item.Id',
                                            '@item.Codigo',
                                            '@item.Nombre',
                                            '@item.UnidadMedida',
                                            '@item.ProductCategoryId',
                                            '@item.BrendId',
                                            '@item.ProviderId',
                                            '@item.PurchasePrice',
                                            '@item.SalePrice',
                                            true)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button type="button"
                                            class="icon-btn"
                                            title="Editar"
                                            onclick="abrirModalArticulo(
                                            false,
                                            '@item.Id',
                                            '@item.Codigo',
                                            '@item.Nombre', 
                                            '@item.UnidadMedida', 
                                            '@item.ProductCategoryId',
                                            '@item.BrendId',
                                            '@item.ProviderId',
                                            '@item.PurchasePrice',
                                            '@item.SalePrice',
                                            false)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button"
                                            class="icon-btn icon-btn-danger"
                                            title="Eliminar"
                                            onclick="abrirModalEliminar('@item.Id', '@item.Nombre');"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalConfirmarEliminar">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                <p class="mt-3">No hay articulos para mostrar</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer">
            <small class="text-muted">Página @paginacion.PageNumber de @paginacion.TotalPages</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <!-- Botón Anterior -->
                    <li class="page-item @(paginacion.PageNumber == 1 ? "disabled" : "")">
                        @if (paginacion.PageNumber > 1)
                        {
                            <a class="page-link" href="@Url.Action("Index", "Articulos", new { Area = "Ventas", pagina = paginacion.PageNumber - 1, tamañoPagina = paginacion.PageSize })">
                                Anterior
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Anterior</span>
                        }
                    </li>

                    @for (int i = inicio; i <= fin; i++)
                    {
                        <li class="page-item @(i == paginacion.PageNumber ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", "Articulos", new { Area = "Ventas", pagina = i, tamañoPagina = paginacion.PageSize })">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Botón Siguiente -->
                    <li class="page-item @(paginacion.PageNumber >= totalPaginas ? "disabled" : "")">
                        @if (paginacion.PageNumber < totalPaginas)
                        {
                            <a class="page-link" href="@Url.Action("Index", "Articulos", new { Area = "Ventas", pagina = paginacion.PageNumber + 1, tamañoPagina = paginacion.PageSize })">
                                Siguiente
                            </a>
                        }
                        else
                        {
                            <span class="page-link">Siguiente</span>
                        }
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>