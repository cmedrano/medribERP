@using PresupuestoMVC.Areas.Ventas.ViewModels.DTOs
@model IEnumerable<ArticuloResponseDTO>

<!-- Tabla de Clientes -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #fd7e14; color: white;">
                    <tr>
                        <th class="py-3">CODIGO</th>
                        <th class="py-3">NOMBRE</th>
                        <th class="py-3">UNIDAD DE MEDIDA</th>
                        <th class="py-3 text-end">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                @* <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width: 40px; height: 40px; background-color: #fd7e14;">
                                            @item.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                    </div>
                                </td> *@
                                <td class="py-4">@(item.Codigo ?? "-")</td>
                                <td class="py-4">@(item.Nombre ?? "-")</td>
                                <td class="py-4">@(item.UnidadMedida ?? "-")</td>
                                <td class="pe-4 py-4 text-end">
                                    <button type="button"
                                            class="btn btn-sm btn-light rounded-circle me-2"
                                            title="Ver"
                                            onclick="abrirModalArticulo(false, '@item.Id', '@item.Codigo', '@item.Nombre', '@item.UnidadMedida', true)">
                                        <i class="bi bi-eye" style="color: #fd7e14;"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-light rounded-circle me-2"
                                            title="Editar"
                                            onclick="abrirModalArticulo(
                                            false,
                                            '@item.Id',
                                            '@item.Codigo',
                                            '@item.Nombre', 
                                            '@item.UnidadMedida', 
                                            '@item.ProductCategoryId',
                                            '@item.BrendId',
                                            '@item.ProviderId',
                                            '@item.PurchasePrice',
                                            '@item.SalePrice',
                                            '@item.Margin',
                                            false)">
                                        <i class="bi bi-pencil" style="color: #fd7e14;"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-light rounded-circle"
                                            title="Eliminar"
                                            onclick="abrirModalEliminar('@item.Id', '@item.Nombre');"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalConfirmarEliminar">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                <p class="mt-3">No hay clientes para mostrar</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>