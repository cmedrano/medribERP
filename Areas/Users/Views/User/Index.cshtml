@using PresupuestoMVC.Models.Entities
@using PresupuestoMVC.Models.DTOs
@using PresupuestoMVC.Enums;
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Usuarios";
    var users = ViewBag.Users as IEnumerable<UserResponseDTO>;
    var roles = ViewBag.Roles;
    var totalUsers = ViewBag.TotalUsers;
    // var paginacion = ViewBag.Paginacion as PaginacionRespuestaDto<RubroResponseDto>;

    // int totalPaginas = (int)Math.Ceiling((double)paginacion.TotalRegistros / ViewBag.TamañoPagina);
    // int inicio = Math.Max(1, ViewBag.PaginaActual - 2);
    // int fin = Math.Min(totalPaginas, ViewBag.PaginaActual + 2);
}
<main class="flex-grow-1 container-main">
    <!-- Header -->
    <div>
        <div class="topbar">
            <div class="searchbox">
                <i class="bi bi-search"></i>
                <input class="form-control" type="text" placeholder="Buscar nombre de usuario..." />
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-success-soft"
                        onclick="abrirModalCrear()">
                    <i class=" bi bi-plus-lg me-2" id="btnNuevoArticulo"></i>
                    Nuevo Usuario
                </button>
            </div>
        </div>
        <div class="page-head">
            <div>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <p class="page-subtitle">Sistema de control de usuarios.</p>
            </div>
        </div>
    </div>

    <!-- informacion util rapida -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-4">
            <div class="erp-card metric-card">
                @* <div class="metric-icon"><i class="bi bi-journal-text"></i></div> *@
                <div class="metric-label">Usuarios totales</div>
                <div class="metric-value">@totalUsers</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="erp-card metric-card">
                @* <div class="metric-icon"><i class="bi bi-cash-stack"></i></div> *@
                <div class="metric-label">Administradores</div>
                <div class="metric-value">4</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="erp-card metric-card">
                @* <div class="metric-icon"><i class="bi bi-credit-card-2-front"></i></div> *@
                <div class="metric-label">Operadores</div>
                <div class="metric-value">5</div>
            </div>
        </div>
    </div>
        
        <!-- Grilla de Usuarios -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-tools">
                <div>
                    <h2 class="section-title">Usuarios registrados</h2>
                    <p class="section-subtitle">
                        Mostrando 9 de @totalUsers
                    </p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-modern table-hover align-middle">
                    <thead>
                        <tr>
                            <th class="py-3">Usuario</th>
                            <th class="py-3">Rol</th>
                            <th class="py-3 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        @if (users != null && users.Any())
                        {
                            foreach (var user in users)
                            {
                                <tr>
@*                                     <td class="d-flex fw-bold" data-username="user">
                                        @user.UserName
                                    </td> *@
                                    <td>
                                        <div class="user-cell">
                                            <span class="avatar">
                                                 @user.UserName.Substring(0, 1).ToUpper()
@*                                                 @string.Concat(
                                                         user.UserName
                                                         .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                                         .Take(2)
                                                         .Select(p => p.Substring(0, 1).ToUpper())
                                                         ) *@
                                                </span>
                                            <div>
                                                <p class="user-name">@user.UserName</p>
                                                <p class="user-email">@user.UserEmail</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge-soft badge-cuenta" data-rol="rol">
                                        <i class="bi bi-person-workspace"></i>
                                             @((UserRol)user.Rol)
                                       </span>
                                    </td>
                                    <td class="pe-4 py-4 text-end">
                                        <button class="icon-btn d-none"
                                                onclick="abrirModalEditar(
                                                '@user.Id',
                                                '@user.UserName',
                                                '@((int)user.Rol)'
                                            )">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (User.IsInRole(nameof(UserRol.Administrador)))
                                        {
                                            <button class="icon-btn icon-btn-warning"
                                                 onclick="resetPassword(
                                                '@user.UserEmail',
                                                '@user.UserName',
                                                '@((UserRol)user.Rol)')">
                                                <i class="bi bi-key"></i>
                                            </button>
                                        }
                                        <button class="icon-btn icon-btn-danger d-none"
                                                onclick="abrirModalEliminar(
                                                '@user.Id',
                                                '@user.UserName',
                                                '@((UserRol)user.Rol)'
                                            )">
                                            <i class="bi bi-trash text-danger"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">
                                    No hay usuarios para mostrar
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <small class="text-muted">Página 1 de 19</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Anterior</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item"><a class="page-link" href="#">Siguiente</a></li>
                    </ul>
                </nav>
            </div>
         </div>
     </div>
    
        <!-- Paginación -->
    @*     <nav aria-label="Paginación de rubro">
            <ul class="pagination justify-content-center">
                <!-- Botón Anterior -->
