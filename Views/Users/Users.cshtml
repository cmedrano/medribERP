    <!-- Grilla de Usuarios -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-oca">
            <thead>
                <tr>
                    <th scope="col">Usuario</th>
                    <th scope="col">Rol</th>
                    <th scope="col">Acciones</th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                @if (users != null && users.Any())
                {
                    foreach (var user in users)
                    {
                        <tr>
                            <td data-username="user">
                                @user.UserName
                            </td>
                            <td data-rol="rol">
                                @((UserRol)user.Rol)
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary me-1 btn-edit-user"
                                        onclick="abrirModalEditar(
                                        '@user.Id',
                                        '@user.UserName',
                                        '@((int)user.Rol)'
                                    )">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                <button class="btn btn-sm btn-danger btn-delete-user"
                                        onclick="abrirModalEliminar(
                                        '@user.Id',
                                        '@user.UserName',
                                        '@((UserRol)user.Rol)'
                                    )">
                                    <i class="bi bi-trash"></i>
                                </button>
                                @if (User.IsInRole(nameof(UserRol.Administrador)))
                                {
                                    <button class="btn btn-sm btn-warning"
                                    onclick="resetPassword(
                                        '@user.UserEmail',
                                        '@user.UserName',
                                        '@((UserRol)user.Rol)')">
                                        <i class="bi bi-key"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No hay usuarios para mostrar
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

