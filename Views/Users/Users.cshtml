<!-- Modal de Creación -->
 <div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-success">
            <!-- Header verde -->
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Usuario
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form asp-controller="User" asp-action="CreateUser" method="post">
                <div class="modal-body">

                    <!-- Usuario -->
                    <div class="mb-3">
                        <label for="createUserId" class="form-label">Nombre de usuario</label>
                        <div class="input-group">
                            <input type="string" id="createUserId" name="userName"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="Richard"
                                   required />
                        </div>
                    </div>

                    <!-- Contraseña -->
                    <div class="mb-3">
                        <label for="createPassword" class="form-label">Contraseña</label>
                        <div class="input-group">
                            <input type="string" id="createPassword" name="password"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="contraseña"
                                   required />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label for="CreateEmail" class="form-label">Email</label>
                        <div class="input-group">
                            <input type="string" id="CreateEmail" name="email"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="email"
                                   required />
                        </div>
                    </div>

                    <!-- Rol -->
                    <div class="mb-3">
                        <label for="rolId" class="form-label">Rol</label>
                        <select id="rolId" name="rol"
                                class="form-select" required>
                            <option value="">Seleccionar Rol...</option>
                                @foreach (var rol in ViewBag.Roles)
                                {
                                <option value="@rol.Value">
                                    @rol.Text
                                </option>
                                }
                        </select>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Crear Usuario
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div> 

<!-- Modal de Edición -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-controller="User" asp-action="Edit" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>Editar Usuario
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="editUserId" name="Id" value="" />

                    <!-- Usuario -->
                    <div class="mb-3">
                        <label for="editUsernameId" class="form-label">Nombre de usuario</label>
                        <div class="input-group">
                            <input type="string" id="editUsernameId" name="Username"
                                   class="form-control"
                                   min="0"
                                   step="1"
                                   placeholder="Ryoma"
                                   required />
                        </div>
                    </div>

                    <!-- Rol -->
                    <div class="mb-3">
                        <label for="editRolId" class="form-label">Rol</label>
                        <select id="editRolId" name="rol"
                                class="form-select" required>
                            <option value="">Seleccionar rol...</option>
                            @foreach (var rol in roles)
                            {
                                <option value="@rol.Value">
                                    @rol.Text
                                </option>
                            }   
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <!-- Header rojo -->
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form asp-controller="User" asp-action="Delete" method="post">
                <div class="modal-body">
                    <!-- Campo oculto para el ID -->
                    <input type="hidden" id="deleteUserId" name="id" />

                    <!-- Mensaje de confirmación -->
                    <div class="text-center">
                        <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                        <h5 class="mt-3">¿Estás seguro de eliminar el usuario?</h5>
                        <p class="text-muted">
                            Esta acción no se puede deshacer. El usuario será eliminado permanentemente.
                        </p>

                        <!-- Información del usuario a eliminar -->
                        <div class="alert alert-light mt-3 text-start" id="deleteRubroInfo">
                            <div class="row">
                                <div class="col-6"><strong>Usuario:</strong> <span id="deleteUsernameId">-</span></div>
                                <div class="col-6 mt-2"><strong>Rol:</strong> <span id="deleteRol">-</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- modal reset password -->
 <div class="modal fade" id="modalReset" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-warning">
            <!-- Header amarillo -->
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Cambiar contraseña
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <!-- Formulario -->
            <form asp-controller="User" asp-action="ResetPassword" method="post">
                <div class="modal-body">

                    <!-- email -->
                    <div class="mb-3">
                        <label for="createUserId" class="form-label">Generar automaticamente una nueva contraseña para el siguiente usuario?, NOTA: la nueva contraseña se enviara por correo</label>
                        <div class="input-group">
                            <input type="hidden" id="email" name="email" />
                        </div>
                    </div>

                    <!-- Información del usuario -->
                    <div class="alert alert-light mt-3 text-start" id="resetPasswordId">
                        <div class="row">
                            <div class="col-6"><strong>Correo:</strong> <span id="emailInfo">-</span></div>
                            <div class="col-6"><strong>Usuario:</strong> <span id="username">-</span></div>
                            <div class="col-6"><strong>Rol:</strong> <span id="userRoleId">-</span></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle me-1"></i>confirmar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div> 

 <script>

    const userRole = "@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value";

    function abrirModalEditar(id, user, rol) {
        // Llenar formulario
        document.getElementById('editUserId').value = id;
        document.getElementById('editUsernameId').value = user;
        document.getElementById('editRolId').value = rol;

        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalEditar'));
        modal.show();
    }

    function abrirModalCrear() {
        if (userRole !== 'Administrador') {
            Swal.fire({
                icon: 'warning',
                title: 'Acceso denegado',
                text: 'No tenés permisos para crear usuarios'
            });
            return;
        }
        // Resetear formulario
        document.getElementById('createUserId').value = '';
        document.getElementById('createPassword').value = '';
        document.getElementById('CreateEmail').value = '';
        document.getElementById('rolId').value = '';

        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalCrear'));
        modal.show();
    }

    function abrirModalEliminar(id, user, rol) {
        // Llenar formulario
        document.getElementById('deleteUserId').value = id;
        document.getElementById('deleteUsernameId').innerText = user;
        document.getElementById('deleteRol').innerText = rol;

        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        modal.show();
    }

    function resetPassword(email, username, rol) {
        if (userRole !== 'Administrador') {
            Swal.fire({
                icon: 'warning',
                title: 'Acceso denegado',
                text: 'No tenés permisos para utilizar esta opcion'
            });
            return;
        }
        console.log("reset para:", email, username)
        document.getElementById('email').value = email;
        document.getElementById('emailInfo').innerText = email;
        document.getElementById('username').innerText = username;
        document.getElementById('userRoleId').innerText = rol;

        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('modalReset'));
        modal.show();
    }

