@using PresupuestoMVC.Models.ViewModels
@model RecoverViewModel

@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #f8f9fa;
                min-height: 100vh;
                display: flex;
                align-items: center;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            }

            .card-forgot-password {
                max-width: 450px;
                width: 100%;
                padding: 20px;
            }
    </style>
</head>

<body>
    <div class ="container">
        <div class="card card-forgot-password mx-auto shadow-sm border-0">
            <div class="card-body">
                <div class="text-center mb-4">
                    <i class="bi bi-key text-primary" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">¿Olvidaste tu contraseña?</h3>
                    <p class="text-muted">Ingresa tu correo electrónico con el cual te registraste y te enviaremos las instrucciones para que restablezcas tu contraseña.</p>
                </div>

                <form asp-action="Recover" method="post">
                    <div class="mb-3">
                        <label for="email" class="form-label">Correo electrónico</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="nombre@ejemplo.com" required>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Enviar enlace de recuperación</button>
                        <a asp-action="Login" class="btn btn-outline-secondary mt-2">Volver al inicio de sesión</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
