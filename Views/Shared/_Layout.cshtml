@{
    var modules = User.Claims
        .Where(c => c.Type == "Module")
        .Select(c => c.Value)
        .ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PresupuestoMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PresupuestoMVC.styles.css" asp-append-version="true" />

</head>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 border-end border-bottom border-3 border-dark">
                <div class="d-flex flex-column align-items-center align-items-sm-start px-3 pt-2 text-white h-100 sidebar">
                    <a href="/" class="d-flex align-items-center pb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                        <span class="fs-3 d-none d-sm-inline sidebar-type-color fw-bold border-bottom pb-1">Avisur</span>
                    </a>

                    <!-- Menú -->
                    <li class="nav-item">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link align-middle px-0 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home")">
                            <i class="fs-4 bi-house text-muted"></i> <span class="ms-1 d-none text-muted d-sm-inline">Menú</span>
                        </a>
                    </li>

                    @{
                        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var isBudgetSection =
                        currentController == "Budget" ||
                        currentController == "Diary" ||
                        currentController == "Category" ||
                        currentController == "Account";
                        var isSalesSection =
                        currentController == "Articulos" ||
                        currentController == "Clientes";
                    }
                    <!-- Areas Accounting-->
                    @if (modules.Contains("accounting"))
                    {
                        <!-- Presupuesto -->
                        <li>
                            <a class="nav-link px-0 align-middle d-flex justify-content-between align-items-center"
                               data-bs-toggle="collapse"
                               href="#budgetSubmenu"
                               role="button"
                               aria-expanded="false"
                               aria-controls="budgetSubmenu">

                                <span>
                                    <i class="bi bi-wallet2 fs-4 text-muted"></i>
                                    <span class="ms-1 d-none d-sm-inline text-muted">Presupuesto</span>
                                </span>

                                <i class="bi bi-chevron-down small"></i>
                            </a>

                            <div class="collapse @(isBudgetSection ? "show" : "")"
                                 id="budgetSubmenu">

                                <ul class="nav flex-column ms-4">

                                    <li>
                                        <a asp-area="Accounting" asp-controller="Budget" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Budget")">
                                            @* <i class="bi bi-list-ul me-1"></i> *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Listado</span>
                                        </a>
                                    </li>

                                    <li>
                                        <a asp-area="Accounting" asp-controller="Diary" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Diary")">
                                            @* <i class="fs-4 bi-cash-stack"></i>  *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Diario</span>
                                        </a>
                                    </li>

                                    <li>
                                        <a asp-area="Accounting" asp-controller="Category" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category")">
                                            @* <i class="fs-4 bi-file-earmark-text"></i> *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Rubros</span>
                                        </a>
                                    </li>

                                    <li>
                                        <a asp-area="Accounting" asp-controller="Account" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Account")">
                                            @* <i class="fs-4 bi-building"></i>  *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Cuentas</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    }
           
                    <!-- Areas Ventas -->
                    @if (modules.Contains("sales"))
                    {
                        <!-- Ventas -->
                        <li>
                            <a class="nav-link px-0 align-middle d-flex justify-content-between align-items-center"
                               data-bs-toggle="collapse"
                               href="#salesSubmenu"
                               role="button"
                               aria-expanded="false"
                               aria-controls="salesSubmenu">

                                <span>
                                    <i class="bi bi-box-seam fs-4 text-muted"></i>
                                    <span class="ms-1 d-none d-sm-inline text-muted">Ventas</span>
                                </span>

                                <i class="bi bi-chevron-down small"></i>
                            </a>

                            <div class="collapse @(isSalesSection ? "show" : "")"
                                 id="salesSubmenu">

                                <ul class="nav flex-column ms-4">

                                    <li>
                                        <a asp-area="Ventas" asp-controller="Articulos" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Budget")">
                                            @* <i class="bi bi-list-ul me-1"></i> *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Articulos</span>
                                        </a>
                                    </li>

                                    <li>
                                        <a asp-area="Ventas" asp-controller="Clientes" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Diary")">
                                            @* <i class="fs-4 bi-cash-stack"></i>  *@
                                            <span class="ms-1 d-none d-sm-inline text-muted">Clientes</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    }
          

                    <!-- Areas Users-->
                    @if (modules.Contains("users"))
                    {
                        <!-- Usuarios -->
                        <li>
                            <a asp-area="Users" asp-controller="User" asp-action="Index" class="nav-link px-0 align-middle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User")">
                                <i class="fs-4 bi-person text-muted"></i>
                                <span class="ms-1 d-none d-sm-inline text-muted">Usuarios</span>
                            </a>
                        </li>
                    }
           

                    <hr>
                    <div class="dropdown pb-4 mt-auto">
                        <a href="#" class="d-flex align-items-center text-white text-decoration-none" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-3 me-2 sidebar-type-color"></i>
                            <span class="d-none d-sm-inline mx-1 sidebar-type-color">Mi Cuenta</span>
                        </a>
                        <ul class="dropdown-menu text-small shadow" aria-labelledby="dropdownUser1">
                            <li>
                                <button class="dropdown-item">
                                    <i class="bi bi-gear-fill me-2"></i>
                                    <span>Configuracion</span>
                                </button>
                            </li>
                            <li>
                                <button id="darkModeBtn" class="dropdown-item" onclick="toggleDarkMode()">
                                    <i id="darkModeIcon" class="bi bi-moon me-2"></i>
                                    <span id="darkModeText">Modo Oscuro</span>
                                </button>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <form asp-area="" asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    <span>Cerrar Sesión</span>
                                </button>
                            </form>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- Main Content -->
            <div class="col-md-9 col-lg-10 main-content border-bottom border-3 border-dark min-vh-100">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Footer Content -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container-fluid">
            &copy; 2025 - PresupuestoMVC - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            function toggleDarkMode() {
            const body = document.body;
            const isDarkMode = body.classList.toggle('dark-mode');

            const text = document.getElementById('darkModeText');
            const icon = document.getElementById('darkModeIcon');

            if (isDarkMode) {
                text.textContent = 'Modo Claro';
                icon.className = 'bi bi-sun me-2';
                localStorage.setItem('theme', 'dark');
            } else {
                text.textContent = 'Modo Oscuro';
                icon.className = 'bi bi-moon me-2';
                localStorage.setItem('theme', 'light');
            }
        }

        // Cargar preferencia al iniciar
        document.addEventListener('DOMContentLoaded', () => {
            const theme = localStorage.getItem('theme');

            if (theme === 'dark') {
                document.body.classList.add('dark-mode');
                document.getElementById('darkModeText').textContent = 'Modo Claro';
                document.getElementById('darkModeIcon').className = 'bi bi-sun me-2';
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
