@{
    var modules = User.Claims
        .Where(c => c.Type == "Module")
        .Select(c => c.Value)
        .ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PresupuestoMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PresupuestoMVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="layout">
        <div class="sidebar">
            <a href="/" class="text-decoration-none text-black brand">
                Avisur
            </a>

            <!-- Menú -->
            <div class="nav-group-title">General</div>
            <nav class="nav flex-column">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link  @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-house-door"></i>Menú
                </a>
            </nav>
            @{
                var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                var isBudgetSection =
                currentController == "Budget" ||
                currentController == "Diary" ||
                currentController == "Category" ||
                currentController == "Account" ||
                currentController == "Statistics" ||
                currentController == "Period";
                var isSalesSection =
                currentController == "Articulos" ||
                currentController == "Clientes" ||
                currentController == "PriceList";
            }
            <!-- Areas Accounting-->
            @if (modules.Contains("accounting"))
            {
                <!-- Presupuesto -->
                <div class="nav-group-title">Presupuesto</div>
                <nav class="nav flex-column">
                    <a class="nav-link  @(isBudgetSection ? "active" : "")"
                           data-bs-toggle="collapse"
                           href="#budgetSubmenu"
                           role="button"
                           aria-expanded="false"
                           aria-controls="budgetSubmenu">
                        <i class="bi bi-wallet2"></i>Presupuesto
                    </a>

                    <div class="collapse @(isBudgetSection ? "show" : "")"
                         id="budgetSubmenu">

                        <div class="nav-sub">
                            <!-- Listado -->
                            <a asp-area="Accounting" asp-controller="Budget" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Budget" ? "active" : "")">
                                Listado
                            </a>
                            <!-- Diario -->
                            <a asp-area="Accounting" asp-controller="Diary" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Diary" ? "active" : "")">
                                Diario
                            </a>
                            <!-- Rubro -->
                            <a asp-area="Accounting" asp-controller="Category" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                                Rubros
                            </a>
                            <!-- Cuentas -->
                            <a asp-area="Accounting" asp-controller="Account" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Account" ? "active" : "")">
                                Cuentas
                            </a>
                            <!-- Estadisticas -->
                            <a asp-area="Accounting" asp-controller="Statistics" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Statistics" ? "active" : "")">
                                Estadisticas
                            </a>
                            <!-- Periodos -->
                            <a asp-area="Accounting" asp-controller="Period" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Period" ? "active" : "")">
                                Periodos
                            </a>
                        </div>
                    </div>
                </nav>
            }
           
            <!-- Areas Ventas -->
            @if (modules.Contains("sales"))
            {
                <!-- Ventas -->
                <div class="nav-group-title">Ventas</div>
                <nav class="nav flex-column">
                    <a class="nav-link @(isSalesSection ? "active" : "")"
                           data-bs-toggle="collapse"
                           href="#salesSubmenu"
                           role="button"
                           aria-expanded="false"
                           aria-controls="salesSubmenu">
                        <i class="bi bi-box-seam"></i>Ventas
                    </a>

                    <div class="collapse @(isSalesSection ? "show" : "")"
                         id="salesSubmenu">

                        <nav class="nav-sub">
                            <!-- Articulos -->
                            <a asp-area="Ventas" asp-controller="Articulos" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Articulos" ? "active" : "")">
                                Articulos
                            </a>
                            <!-- Clientes -->
                            <a asp-area="Ventas" asp-controller="Clientes" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Clientes" ? "active" : "")">
                                Clientes
                            </a>
                            <!-- lista de precios -->
                            <a asp-area="Ventas" asp-controller="PriceList" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PriceList" ? "active" : "")">
                                Lista de precios
                            </a>
                            <!-- Facturacion -->
                            <a asp-area="Ventas" asp-controller="Facturacion" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PriceList" ? "active" : "")">
                                Facturacion
                            </a>
                        </nav>
                    </div>
                </nav>
            }

          
            <!-- Areas Users-->
            @if (modules.Contains("users"))
            {
                <!-- Usuarios -->
                <div class="nav-group-title">Sistema</div>
                <nav class="nav flex-column">
                    <a asp-area="Users" asp-controller="User" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                        <i class="bi bi-person-gear"></i>
                        Usuarios
                    </a>
                </nav>
            }
            <hr>
            <div class="mt-auto pt-3 border-top" style="position:sticky; bottom:0; background:var(--erp-sidebar);">
                <div class="d-flex align-items-center gap-2 p-2">
                    <div class="text-dark" style="width:40px;height:40px;border-radius:50%;background:#dfe3ff;display:flex;align-items:center;justify-content:center;font-weight:700;">
                        CM
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-dark" style="font-weight:700;font-size:.9rem;">Cristian</div>
                        <div style="font-size:.75rem;color:var(--erp-muted);">Administrador</div>
                    </div>
                </div>
                <form asp-area="" asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                    <div class="d-grid p-2">
                        <button type="submit" class="btn btn-soft w-100">
                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                        </button>
                    </form>
                </div>
            </div>
            <!-- usuario ingresado -->
            @*                       <div class="dropdown pb-4 mt-auto">
                            <a href="#" class="d-flex align-items-center text-white text-decoration-none" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-3 me-2 sidebar-type-color"></i>
                                <span class="d-none d-sm-inline mx-1 sidebar-type-color">Mi Cuenta</span>
                            </a>
                            <ul class="dropdown-menu text-small shadow" aria-labelledby="dropdownUser1">
                                <li>
                                    <button class="dropdown-item">
                                        <i class="bi bi-gear-fill me-2"></i>
                                        <span>Configuracion</span>
                                    </button>
                                </li>
                                <li>
                                    <button id="darkModeBtn" class="dropdown-item" onclick="toggleDarkMode()">
                                        <i id="darkModeIcon" class="bi bi-moon me-2"></i>
                                        <span id="darkModeText">Modo Oscuro</span>
                                    </button>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <form asp-area="" asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right me-2"></i>
                                        <span>Cerrar Sesión</span>
                                    </button>
                                </form>
                            </ul>
                        </div> *@
                 
        </div>
        <!-- Main Content -->
        <div class=" content">
            @RenderBody()
        </div>
    </div>

    <!-- Footer Content -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container-fluid">
            &copy; 2026 - Avisur - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function toggleDarkMode() {
        const body = document.body;
        const isDarkMode = body.classList.toggle('dark-mode');

        const text = document.getElementById('darkModeText');
        const icon = document.getElementById('darkModeIcon');

        if (isDarkMode) {
        text.textContent = 'Modo Claro';
        icon.className = 'bi bi-sun me-2';
        localStorage.setItem('theme', 'dark');
        } else {
        text.textContent = 'Modo Oscuro';
        icon.className = 'bi bi-moon me-2';
        localStorage.setItem('theme', 'light');
        }
        }

        // Cargar preferencia al iniciar
        document.addEventListener('DOMContentLoaded', () => {
        const theme = localStorage.getItem('theme');

        if (theme === 'dark') {
        document.body.classList.add('dark-mode');
        document.getElementById('darkModeText').textContent = 'Modo Claro';
        document.getElementById('darkModeIcon').className = 'bi bi-sun me-2';
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
