@model PresupuestoMVC.Models.Entities.PriceList

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <!-- Header azul -->
        <div class="card-header text-white"
             style="background: linear-gradient(90deg, #0d6efd, #0a58ca);">
            <h4 class="mb-0">Detalle de Lista de Precio</h4>
        </div>

        <!-- Body -->
        <div class="card-body">

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold text-primary">
                    Nombre:
                </div>
                <div class="col-sm-9">
                    <span class="badge bg-primary fs-6">
                        @Model.Nombre
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold text-primary">
                    Estado:
                </div>
                <div class="col-sm-9">
                    @if (Model.Activo)
                    {
                        <span class="badge bg-info text-dark">Activa</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactiva</span>
                    }
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer bg-light text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-outline-primary me-2">
                ✏ Editar
            </a>

            <a asp-action="Index"
               class="btn btn-primary">
                ← Volver
            </a>
        </div>

    </div>

</div>