                        <article class="menu-card">
                            <div class="menu-card-header">
                                <span class="menu-icon"><i class="bi bi-person"></i></span>
                                <span class="menu-mini-chip">@ViewBag.TotalUsers usuarios</span>
                            </div>
                            <h3 class="menu-title">Usuarios</h3>
                            <p class="menu-description">Administración de usuarios, perfiles, permisos y acceso al sistema.</p>
@*                             <div class="menu-stats">
                                <div class="menu-stat"><span>Activos</span><strong>@Model.ActiveClients</strong></div>
                                <div class="menu-stat"><span>Administradores</span><strong>4</strong></div>
                            </div> *@
                            <div class="menu-actions">
                                <a asp-area="Users" asp-controller="User" asp-action="Index" class="btn btn-primary btn-block"><i class="bi bi-arrow-right-circle"></i>Administrar</a>
                                <a href="#" class="btn btn-ghost btn-block"><i class="bi bi-plus-lg"></i>Nuevo usuario</a>
                            </div>
                        </article>
                    }
                    @* ventas *@
                    @if (modules.Contains("sales"))
                    {
                        @* clientes *@
                        <article class="menu-card">
                            <div class="menu-card-header">
                                <span class="menu-icon"><i class="bi bi-shop"></i></span>
                                <span class="menu-mini-chip">@clients.Count() clientes</span>
                            </div>
                            <h3 class="menu-title">Clientes</h3>
                            <p class="menu-description">Gestión comercial de clientes, contactos, datos fiscales y condiciones de venta.</p>
@*                             <div class="menu-stats">
                                <div class="menu-stat"><span>Nuevos este mes</span><strong>12</strong></div>
                                <div class="menu-stat"><span>Con cuenta corriente</span><strong>68</strong></div>
                            </div> *@
                            <div class="menu-actions">
                                <a asp-area="Ventas" asp-controller="Clientes" asp-action="Index" class="btn btn-primary btn-block"><i class="bi bi-people"></i>Ver clientes</a>
                                <a href="#" class="btn btn-ghost btn-block"><i class="bi bi-person-plus"></i>Nuevo cliente</a>
                            </div>
                        </article>

                        @* articulos *@
                        <article class="menu-card">
                            <div class="menu-card-header">
                                <span class="menu-icon"><i class="bi bi-box-seam"></i></span>
                                <span class="menu-mini-chip">@articles.Count() artículos</span>
                            </div>
                            <h3 class="menu-title">Artículos</h3>
                            <p class="menu-description">Catálogo de productos, rubros, marcas, proveedores y control de precios.</p>
@*                             <div class="menu-stats">
                                <div class="menu-stat"><span>Stock bajo</span><strong>17</strong></div>
                                <div class="menu-stat"><span>Nuevos esta semana</span><strong>5</strong></div>
                            </div> *@
                            <div class="menu-actions">
                                <a hasp-area="Ventas" asp-controller="Articulos" asp-action="Index" class="btn btn-primary btn-block"><i class="bi bi-box"></i>Ver artículos</a>
                                <a href="#" class="btn btn-ghost btn-block"><i class="bi bi-plus-lg"></i>Nuevo artículo</a>
                            </div>
                        </article>

                        @* lista de precios *@
                        <article class="menu-card">
