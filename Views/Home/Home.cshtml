@{
    ViewData["Title"] = "Inicio";
    var modules = User.Claims
        .Where(c => c.Type == "Module")
        .Select(c => c.Value)
        .ToList();
}

<div class="container mt-4">

    <h2 class="mb-5 text-center">Dashboard</h2>

    <div class="row g-4 justify-content-center">


        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <!-- Areas Accounting-->
            @if (modules.Contains("accounting"))
            {
                <!-- Presupuesto -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow border-0 rounded-4 h-100 dashboard-card">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div>
                                        <i class="bi bi-wallet2 fs-1 text-primary me-3"></i>
                                    </div>
                                    <span class="badge bg-light text-dark fs-4">
                                        @ViewBag.TotalBudgets
                                    </span>
                                </div>
                                <h5 class="fw-bold">Presupuesto</h5>
                                <p class="text-muted small mb-4">
                                    Gestiona tu presupuesto mensual, controla ingresos y egresos.
                                </p>
                                <a asp-area="Accounting" asp-controller="Budget" asp-action="Index" class="stretched-link btn btn-primary w-100 rounded-pill">
                                    <i class="bi bi-arrow-right-circle me-1"></i>
                                    Ver Presupuesto
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Gastos -->
              @* <div class="col-12 col-md-6 col-lg-4">
                 <div class="card shadow-sm border-0 h-100">
                 <div class="card-body">
                 <div class="d-flex align-items-center mb-3">
                 <i class="bi bi-cash-stack fs-1 text-success me-3"></i>
                 <h5 class="card-title mb-0">Gastos</h5>
                 </div>
                 <p class="card-text text-muted">
                 Registra y administra todos tus gastos de forma simple.
                 </p>
                 <a asp-controller="Gasto" asp-action="Index" class="btn btn-success">
                 Ver Gastos
                 </a>
                 </div>
                 </div>
                 </div> *@

                <!-- Diario -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow border-0 rounded-4 h-100 dashboard-card">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div class="">
                                        <i class="bi bi-cash-stack fs-1 text-dark me-3"></i>
                                    </div>
                                    <span class="badge bg-light text-dark fs-4">
                                        @ViewBag.TotalGsstos
                                    </span>
                                </div>
                                <h5 class="fw-bold">Diario</h5>
                                <p class="text-muted small mb-4">
                                    Registro diario.
                                </p>
                            </div>
                            <a asp-area="Accounting" asp-controller="Diary" asp-action="Index" class="stretched-link btn btn-dark w-100 rounded-pill">
                                <i class="bi bi-arrow-right-circle me-1"></i>
                                Ver Diario
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Rubros -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow border-0 rounded-4 h-100 dashboard-card">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div>
                                        <i class="bi bi-file-earmark-text fs-1 text-danger me-3"></i>
                                    </div>
                                    <span class="badge bg-light text-dark fs-4">
                                        @ViewBag.TotalCategories
                                    </span>
                                </div>
                                <h5 class="fw-bold">Rubros</h5>
                                <p class="text-muted small mb-4">
                                    Visualiza la lista de rubros disponibles.
                                </p>
                            </div>
                            <a asp-area="Accounting" asp-controller="Category" asp-action="Index" class="stretched-link btn btn-danger w-100 rounded-pill">
                                <i class="bi bi-arrow-right-circle me-1"></i>
                                Ver Rubros
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Cuentas -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow border-0 rounded-4 h-100 dashboard-card">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div class="">
                                        <i class="bi bi-building fs-1 text-info me-3 "></i>
                                    </div>
                                    <span class="badge bg-light text-dark fs-4">
                                        @ViewBag.TotalAccounts
                                    </span>
                                </div>
                                <h5 class="fw-bold">Cuentas</h5>
                                <p class="text-muted small mb-4">
                                    Administrar cuentas.
                                </p>
                            </div>
                            <a asp-area="Accounting" asp-controller="Account" asp-action="Index" class="stretched-link btn btn-info w-100 rounded-pill">
                                <i class="bi bi-arrow-right-circle me-1"></i>
                                Ver Cuentas
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Areas Users-->
            @if (modules.Contains("users"))
            {
                <!-- Usuarios -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow border-0 rounded-4 h-100 dashboard-card">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div class="">
                                        <i class="bi bi-person fs-1 text-secondary me-3"></i>
                                    </div>
                                    <span class="badge bg-light text-dark fs-4">
                                        @ViewBag.TotalUsers
                                    </span>
                                </div>
                                <h5 class="fw-bold">Usuarios</h5>
                                <p class="text-muted small mb-4">
                                    Total de usuarios registrados en el sistema.
                                </p>
                            </div>
                            <a asp-area="Users" asp-controller="User" asp-action="Index" class="stretched-link btn btn-secondary w-100 rounded-pill">
                                <i class="bi bi-arrow-right-circle me-1"></i>
                                Administrar
                            </a>
                        </div>
                    </div>
                </div>
            }
 

            <!-- Card test-->
@*             <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden">

                    <div class="position-absolute top-0 start-0 h-100 bg-danger" style="width:5px;"></div>

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted mb-0">Rubros</h6>
                            <i class="bi bi-file-earmark-text text-danger fs-4"></i>
                        </div>

                        <h2 class="fw-bold mb-2">23</h2>
                        <p class="text-muted small">
                            Diferentes categorías registradas.
                        </p>

                        <a href="#" class="stretched-link text-danger fw-semibold text-decoration-none">
                            Administrar →
                        </a>

                    </div>
                </div>
            </div> *@

            <!-- Areas Ventas-->
            @if (modules.Contains("sales"))
            {
                <!-- Clientes -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid #6f42c1 !important;">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-shop fs-1 me-3" style="color: #6f42c1;"></i>
                                <h5 class="card-title mb-0">Clientes</h5>
                            </div>
                            <p class="card-text text-muted">
                                Administrar clientes.
                            </p>
                            <a asp-area="Ventas" asp-controller="Clientes" asp-action="Index" class="btn text-white fw-bold"
                               style="background-color: #6f42c1; border: none;">
                                Ver Clientes
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Artículos -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid #fd7e14 !important;">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-box-seam fs-1 me-3" style="color: #fd7e14;"></i>
                                <h5 class="card-title mb-0">Artículos</h5>
                            </div>
                            <p class="card-text text-muted">
                                Gestión de artículos y productos.
                            </p>
                            <a asp-area="Ventas" asp-controller="Articulos" asp-action="Index" class="btn text-white fw-bold"
                               style="background-color: #fd7e14; border: none;">
                                Ver Artículos
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Lista de precios -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-tags fs-1 text-warning me-3"></i>
                            <h5 class="card-title mb-0">Lista de Precios</h5>
                        </div>
                        <p class="card-text text-muted">
                            Gestiona productos y precios.
                        </p>
                        <a asp-controller="PriceList" asp-action="Index" class="btn btn-warning">
                            Ver Lista de Precios
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<style>
    .card-body{
        display: flex;
        flex-direction: column;
        justify-content: space-around;
    }
</style>
