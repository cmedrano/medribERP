                    </div>
                </div>
                <div class="status-list">
                    <div class="status-item">
                        <div class="status-left">
                            <span class="status-dot dot-danger"><i class="bi bi-exclamation-lg"></i></span>
                            <div>
                                <p class="status-name">Cantidad de articulos</p>
                                <p class="status-meta">articulos que hay en el sistema</p>
                            </div>
                        </div>
                        <div class="status-value">@articles.Count()</div>
                    </div>
                    <div class="status-item">
                        <div class="status-left">
                            <span class="status-dot dot-primary"><i class="bi bi-receipt"></i></span>
                            <div>
                                <p class="status-name">Cantidad de clientes</p>
                                <p class="status-meta">los clientes en el sistema</p>
                            </div>
                        </div>
                        <div class="status-value">@clients.Count()</div>
                    </div>
                    <div class="status-item">
                        <div class="status-left">
                            <span class="status-dot dot-success"><i class="bi bi-check2-circle"></i></span>
                            <div>
                                <p class="status-name">Cantidad de ventas</p>
                                <p class="status-meta">las ventas que se realizo</p>
                            </div>
                        </div>
                        <div class="status-value">OK</div>
                    </div>
                </div>
            </section>

            <section class="panel-card">
                <div class="panel-header">
                    <div>
                        <h2 class="panel-title">Actividad reciente</h2>
                        <p class="panel-subtitle">Últimos movimientos importantes del sistema.</p>
                    </div>
                </div>
                <div class="activity-list">
