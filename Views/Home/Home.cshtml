                            </div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-left">
                            <span class="activity-icon"><i class="bi bi-person-workspace"></i></span>
                            <div>
                                <p class="activity-title">Se modificaron permisos</p>
                                <p class="activity-meta">Usuario BraianD · hace 2 h</p>
                            </div>
                        </div>
                    </div>
                    <div class="activity-item">
