@using PresupuestoMVC.Models.ViewModels
@model DashboardViewModel;
@using PresupuestoMVC.Models.DTOs;
@using PresupuestoMVC.Areas.Ventas.ViewModels.DTOs;
@using PresupuestoMVC.Models.Entities;
@{
    ViewData["Title"] = "Inicio";
    var modules = User.Claims
        .Where(c => c.Type == "Module")
        .Select(c => c.Value)
        .ToList();

    var clients = ViewBag.Clients as IEnumerable<ClienteResponseDTO>;
    var articles = ViewBag.Articles as IEnumerable<ArticuloResponseDTO>;
    var priceList = ViewBag.PriceList as IEnumerable<PriceList>;
}

<div class="page">
    <section class="hero-card">
        <div class="hero-left">
            <span class="hero-icon"><i class="bi bi-grid-1x2"></i></span>
            <div>
                <h1 class="hero-title">Dashboard</h1>
                <p class="hero-subtitle">Vista general del negocio con acceso rápido a los módulos clave del ERP, métricas del período y alertas operativas.</p>
            </div>
        </div>

        <div class="hero-actions">
            <a href="#" class="btn btn-soft"><i class="bi bi-arrow-repeat"></i>Actualizar</a>
            <a href="#" class="btn btn-primary"><i class="bi bi-plus-lg"></i>Nueva operación</a>
        </div>
    </section>

    <section class="dashboard-grid">
        <div class="left-stack">
            <div class="kpi-grid">
                <article class="kpi-card">
                    <div class="kpi-top">
                        <span class="kpi-icon"><i class="bi bi-cash-stack"></i></span>
                        <span class="kpi-chip chip-success"><i class="bi bi-arrow-up"></i>0%</span>
                    </div>
                    <div class="kpi-label">Ventas del mes</div>
                    <div class="kpi-value">$ @Model.SalesMonth.ToString("N2")</div>
                    <div class="kpi-meta">Comparado con el mes anterior</div>
                </article>

                <article class="kpi-card">
                    <div class="kpi-top">
                        <span class="kpi-icon"><i class="bi bi-wallet2"></i></span>
                        <span class="kpi-chip chip-warning"><i class="bi bi-exclamation-triangle"></i>0%</span>
                    </div>
                    <div class="kpi-label">Presupuesto usado</div>
                    <div class="kpi-value">$ @Model.UsedBudget.ToString("N2")</div>
                    <div class="kpi-meta">Quedan $ @Model.ActiveClients.ToString("N2") disponibles</div>
                </article>

                <article class="kpi-card">
                    <div class="kpi-top">
                        <span class="kpi-icon"><i class="bi bi-people"></i></span>
                        <span class="kpi-chip chip-success"><i class="bi bi-person-plus"></i>0</span>
                    </div>
                    <div class="kpi-label">Clientes activos</div>
                    <div class="kpi-value">@Model.ActiveClients</div>
                    <div class="kpi-meta">8 nuevos en los últimos 30 días</div>
                </article>

@*                 <article class="kpi-card">
                    <div class="kpi-top">
                        <span class="kpi-icon"><i class="bi bi-box-seam"></i></span>
                        <span class="kpi-chip chip-danger"><i class="bi bi-bell"></i>5 críticos</span>
                    </div>
                    <div class="kpi-label">Stock bajo</div>
                    <div class="kpi-value">17</div>
                    <div class="kpi-meta">Artículos por debajo del mínimo</div>
                </article> *@
            </div>

            <section class="menu-section">
                <div class="section-heading">
                    <div>
                        <h2 class="section-title">Accesos rápidos</h2>
                        <p class="section-subtitle">Entrá directo a los módulos más usados y ejecutá acciones frecuentes.</p>
                    </div>
                </div>

                <div class="menu-grid">

                    @* usuarios *@
                    @if (modules.Contains("users"))
