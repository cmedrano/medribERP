@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-4">

    <h2 class="mb-5 text-center">Home</h2>

    <div class="row g-4 justify-content-center">

        <!-- Presupuesto -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-wallet2 fs-1 text-primary me-3"></i>
                            <h5 class="card-title mb-0">Presupuesto</h5>
                        </div>
                        <p class="card-text text-muted">
                            Gestiona tu presupuesto mensual, controla ingresos y egresos.
                        </p>
                        <a asp-controller="Budget" asp-action="Index" class="btn btn-primary">
                            Ver Presupuesto
                        </a>
                    </div>
                </div>
            </div>

            <!-- Gastos -->
@*             <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-cash-stack fs-1 text-success me-3"></i>
                            <h5 class="card-title mb-0">Gastos</h5>
                        </div>
                        <p class="card-text text-muted">
                            Registra y administra todos tus gastos de forma simple.
                        </p>
                        <a asp-controller="Gasto" asp-action="Index" class="btn btn-success">
                            Ver Gastos
                        </a>
                    </div>
                </div>
            </div> *@

            <!-- Diario -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-cash-stack fs-1 text-dark me-3"></i>
                            <h5 class="card-title mb-0">Diario</h5>
                        </div>
                        <p class="card-text text-muted">
                            Registro diario.
                        </p>
                        <a asp-controller="Diary" asp-action="Index" class="btn btn-dark">
                            Ver Diario
                        </a>
                    </div>
                </div>
            </div>

            <!-- Rubros -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-file-earmark-text fs-1 text-danger me-3"></i>
                            <h5 class="card-title mb-0">Rubros</h5>
                        </div>
                        <p class="card-text text-muted">
                            Visualiza un resumen general de difernetes rubros.
                        </p>
                        <a asp-controller="Category" asp-action="Index" class="btn btn-danger">
                            Ver Rubros
                        </a>
                    </div>
                </div>
            </div>

            <!-- Cuentas -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-building fs-1 text-info me-3"></i>
                            <h5 class="card-title mb-0">Cuentas</h5>
                        </div>
                        <p class="card-text text-muted">
                            Administrar cuentas.
                        </p>
                        <a asp-controller="Account" asp-action="Index" class="btn btn-info">
                            Ver Cuentas
                        </a>
                    </div>
                </div>
            </div>

            <!-- Usuarios -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-person fs-1 text-secondary me-3"></i>
                            <h5 class="card-title mb-0">Usuarios</h5>
                        </div>
                        <p class="card-text text-muted">
                            Administrar usuarios.
                        </p>
                        <a asp-controller="User" asp-action="Index" class="btn btn-secondary">
                            Ver Usuarios
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<style>
    .card-body{
        display: flex;
        flex-direction: column;
        justify-content: space-around;
    }
</style>
